<Window x:Class="TypeWhisper.Plugin.LiveTranscript.LiveTranscriptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
        Loaded="Window_Loaded">
    <Border CornerRadius="16"
            Margin="8"
            Padding="18,12"
            MinWidth="220"
            MaxWidth="620"
            Background="#EE11161D"
            BorderBrush="#24FFFFFF"
            BorderThickness="1"
            Cursor="SizeAll"
            RenderTransformOrigin="0.5,0.5"
            x:Name="RootBorder">
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="EntranceScale"
                                ScaleX="1"
                                ScaleY="1" />
                <TranslateTransform x:Name="EntranceTranslate" />
            </TransformGroup>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="0"
                              Opacity="0.4"
                              Color="Black" />
        </Border.Effect>
        <ScrollViewer x:Name="TranscriptScroller"
                      VerticalScrollBarVisibility="Hidden"
                      MaxHeight="112"
                      HorizontalScrollBarVisibility="Disabled">
            <TextBlock x:Name="TranscriptText"
                       Foreground="#E8FFFFFF"
                       FontSize="16"
                       FontWeight="Medium"
                       MaxWidth="584"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       FontFamily="Segoe UI"
                       TextOptions.TextFormattingMode="Display"
                       Text="Listening..." />
        </ScrollViewer>
    </Border>
</Window>

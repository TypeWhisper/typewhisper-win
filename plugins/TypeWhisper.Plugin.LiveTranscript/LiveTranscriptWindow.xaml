<Window x:Class="TypeWhisper.Plugin.LiveTranscript.LiveTranscriptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="Height"
        Width="460"
        ResizeMode="NoResize"
        Loaded="Window_Loaded">
    <Border CornerRadius="12"
            Margin="8"
            Padding="14,10"
            Background="#EE11161D"
            BorderBrush="#24FFFFFF"
            BorderThickness="1"
            x:Name="RootBorder">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="0"
                              Opacity="0.4"
                              Color="Black" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid x:Name="DragHandle"
                  Height="8"
                  Margin="0,0,0,4"
                  Cursor="SizeAll"
                  MouseLeftButtonDown="DragHandle_MouseLeftButtonDown">
                <Border Width="28"
                        Height="3"
                        CornerRadius="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#24FFFFFF" />
            </Grid>

            <ScrollViewer x:Name="TranscriptScroller"
                          Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          MaxHeight="200"
                          HorizontalScrollBarVisibility="Disabled">
                <TextBlock x:Name="TranscriptText"
                           Foreground="#E8FFFFFF"
                           FontSize="16"
                           TextWrapping="Wrap"
                           FontFamily="Segoe UI"
                           LineHeight="20"
                           TextOptions.TextFormattingMode="Display"
                           Text="Listening..." />
            </ScrollViewer>
        </Grid>
    </Border>
</Window>

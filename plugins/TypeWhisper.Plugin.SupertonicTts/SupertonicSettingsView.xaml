<UserControl x:Class="TypeWhisper.Plugin.SupertonicTts.SupertonicSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <SolidColorBrush x:Key="HintBrush" Color="#808080"/>
        <SolidColorBrush x:Key="LabelBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#00A6A6"/>
    </UserControl.Resources>

    <StackPanel Margin="0,4" MaxWidth="520">
        <TextBlock x:Name="TitleText"
                   Foreground="{StaticResource LabelBrush}"
                   FontWeight="SemiBold"
                   Margin="0,0,0,6"/>

        <TextBlock x:Name="DescriptionText"
                   Foreground="{StaticResource TextBrush}"
                   Opacity="0.8"
                   TextWrapping="Wrap"
                   FontSize="12"
                   Margin="0,0,0,8"/>

        <TextBlock x:Name="StatusText"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"/>

        <CheckBox x:Name="LicenseCheckBox"
                  Checked="OnLicenseChanged"
                  Unchecked="OnLicenseChanged"
                  Margin="0,0,0,8"/>

        <ProgressBar x:Name="DownloadProgress"
                     Height="4"
                     Minimum="0"
                     Maximum="100"
                     Visibility="Collapsed"
                     Background="#333"
                     Foreground="{StaticResource AccentBrush}"
                     Margin="0,0,0,8"/>

        <Button x:Name="DownloadButton"
                HorizontalAlignment="Left"
                Padding="14,6"
                Click="OnDownloadClick"
                Margin="0,0,0,12"/>

        <Separator Margin="0,0,0,10"/>

        <TextBlock x:Name="SpeedLabel"
                   Foreground="{StaticResource LabelBrush}"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Slider x:Name="SpeedSlider"
                    Minimum="0.9"
                    Maximum="1.5"
                    SmallChange="0.05"
                    LargeChange="0.1"
                    ValueChanged="OnSpeedChanged"/>
            <TextBlock x:Name="SpeedValueText"
                       Grid.Column="1"
                       MinWidth="44"
                       Margin="10,0,0,0"
                       Foreground="{StaticResource TextBrush}"
                       VerticalAlignment="Center"/>
        </Grid>

        <TextBlock x:Name="StepsLabel"
                   Foreground="{StaticResource LabelBrush}"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Slider x:Name="StepsSlider"
                    Minimum="1"
                    Maximum="16"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True"
                    ValueChanged="OnStepsChanged"/>
            <TextBlock x:Name="StepsValueText"
                       Grid.Column="1"
                       MinWidth="44"
                       Margin="10,0,0,0"
                       Foreground="{StaticResource TextBrush}"
                       VerticalAlignment="Center"/>
        </Grid>

        <TextBlock x:Name="SourceText"
                   FontSize="11"
                   Foreground="{StaticResource HintBrush}"
                   TextWrapping="Wrap"/>
        <TextBlock x:Name="LicenseText"
                   FontSize="11"
                   Foreground="{StaticResource HintBrush}"
                   TextWrapping="Wrap"
                   Margin="0,2,0,0"/>
    </StackPanel>
</UserControl>

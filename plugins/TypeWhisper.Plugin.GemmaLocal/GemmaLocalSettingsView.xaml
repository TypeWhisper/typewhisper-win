<UserControl x:Class="TypeWhisper.Plugin.GemmaLocal.GemmaLocalSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <SolidColorBrush x:Key="HintBrush" Color="#808080"/>
        <SolidColorBrush x:Key="LabelBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#4CAF50"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#D32F2F"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#7C4DFF"/>
    </UserControl.Resources>

    <StackPanel Margin="0,4" MaxWidth="500">
        <!-- Model Selection -->
        <TextBlock x:Name="ModelLabel" Foreground="{StaticResource LabelBrush}"
                   FontWeight="SemiBold" Margin="0,0,0,8"/>

        <ItemsControl x:Name="ModelList">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="#1E1E1E" CornerRadius="6" Padding="12,10" Margin="0,0,0,6"
                            BorderBrush="#333" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"/>
                                    <TextBlock Text=" ⭐" Visibility="{Binding RecommendedVisibility}"
                                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="{Binding SizeText}" FontSize="11"
                                           Foreground="{StaticResource HintBrush}" Margin="0,2,0,0"/>
                                <TextBlock Text="{Binding StatusText}" FontSize="11"
                                           Foreground="{Binding StatusBrush}" Margin="0,2,0,0"/>
                                <!-- Progress bar -->
                                <ProgressBar x:Name="ProgressBar" Height="4" Margin="0,4,0,0"
                                             Visibility="{Binding ProgressVisibility}"
                                             Value="{Binding Progress}" Maximum="100"
                                             Background="#333" Foreground="{StaticResource AccentBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                <Button Content="{Binding ActionText}" Padding="14,6"
                                        Click="OnModelAction" Tag="{Binding Id}"
                                        IsEnabled="{Binding ActionEnabled}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Status -->
        <Border x:Name="StatusPanel" Visibility="Collapsed"
                Background="#252525" CornerRadius="6" Padding="12,8" Margin="0,8,0,0">
            <TextBlock x:Name="StatusText" FontSize="12"
                       Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
        </Border>
    </StackPanel>
</UserControl>

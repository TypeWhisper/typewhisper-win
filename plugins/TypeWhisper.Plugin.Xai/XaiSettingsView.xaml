<UserControl x:Class="TypeWhisper.Plugin.Xai.XaiSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="0,4" MaxWidth="520">
        <TextBlock Text="API Key" FontWeight="SemiBold" Margin="0,0,0,4" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <PasswordBox x:Name="ApiKeyBox" PasswordChanged="OnPasswordChanged" />
            <Button Grid.Column="1" Margin="8,0,0,0" Padding="12,4"
                    Click="OnTestClick" x:Name="TestButton" />
        </Grid>
        <TextBlock x:Name="ApiKeyHintText" Margin="0,4,0,0" FontSize="11" Foreground="Gray" TextWrapping="Wrap" />
        <TextBlock x:Name="StatusText" Margin="0,6,0,0" FontSize="12" />

        <StackPanel x:Name="SettingsSection" Margin="0,16,0,0" Visibility="Collapsed">
            <TextBlock x:Name="TranscriptionModelLabel" FontWeight="SemiBold" Margin="0,0,0,4" />
            <ComboBox x:Name="TranscriptionModelPicker"
                      DisplayMemberPath="DisplayName"
                      SelectionChanged="OnTranscriptionModelChanged"
                      Margin="0,0,0,16" />

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="LlmModelLabel" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" x:Name="RefreshModelsButton" Padding="12,4"
                        Click="OnRefreshModelsClick" />
            </Grid>
            <ComboBox x:Name="LlmModelPicker"
                      DisplayMemberPath="DisplayName"
                      SelectionChanged="OnLlmModelChanged" />
            <TextBlock x:Name="LlmModelHintText" Margin="0,4,0,16" FontSize="11" Foreground="Gray" TextWrapping="Wrap" />

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TtsVoiceLabel" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" x:Name="RefreshVoicesButton" Padding="12,4"
                        Click="OnRefreshVoicesClick" />
            </Grid>
            <ComboBox x:Name="VoicePicker"
                      DisplayMemberPath="DisplayName"
                      SelectionChanged="OnVoiceChanged" />
            <TextBlock x:Name="VoiceHintText" Margin="0,4,0,10" FontSize="11" Foreground="Gray" TextWrapping="Wrap" />

            <TextBlock x:Name="CustomVoiceLabel" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBox x:Name="CustomVoiceBox" TextChanged="OnCustomVoiceChanged" />
            <TextBlock x:Name="CustomVoiceHintText" Margin="0,4,0,10" FontSize="11" Foreground="Gray" TextWrapping="Wrap" />

            <CheckBox x:Name="LowLatencyCheckBox"
                      Checked="OnLowLatencyChanged"
                      Unchecked="OnLowLatencyChanged"
                      Margin="0,2,0,6" />
            <CheckBox x:Name="TextNormalizationCheckBox"
                      Checked="OnTextNormalizationChanged"
                      Unchecked="OnTextNormalizationChanged" />
        </StackPanel>
    </StackPanel>
</UserControl>

<UserControl x:Class="TypeWhisper.Plugin.Linear.LinearSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="0,4">
        <!-- API Key -->
        <TextBlock Text="API Key" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Text="Generate a personal API key at Linear Settings &gt; API &gt; Personal API keys."
                   Foreground="Gray" FontSize="12" Margin="0,0,0,6" TextWrapping="Wrap" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <PasswordBox x:Name="ApiKeyBox" Grid.Column="0" Margin="0,0,8,0" />
            <Button x:Name="SaveApiKeyButton" Grid.Column="1" Content="Save" Padding="12,4"
                    Click="OnSaveApiKey" />
        </Grid>

        <!-- Status -->
        <TextBlock x:Name="StatusText" Margin="0,6,0,0" FontSize="12" />

        <!-- Separator -->
        <Separator Margin="0,16,0,12" />

        <!-- Default Team ID -->
        <TextBlock Text="Default Team ID" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="12" Margin="0,0,0,6">
            <Run Text="Required. The UUID of the team where issues will be created." />
            <LineBreak />
            <Run Text="Click 'Fetch Teams' to load your teams, or find the ID in Linear under Settings &gt; Teams." />
        </TextBlock>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TeamIdBox" Grid.Column="0" Margin="0,0,8,0"
                     TextChanged="OnTeamIdChanged" />
            <Button x:Name="FetchTeamsButton" Grid.Column="1" Content="Fetch Teams" Padding="12,4"
                    Click="OnFetchTeams" />
        </Grid>

        <!-- Teams List -->
        <ItemsControl x:Name="TeamsList" Margin="0,6,0,0">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button HorizontalAlignment="Left" Padding="8,4" Margin="0,2"
                            Click="OnSelectTeam" Tag="{Binding Id}"
                            Background="Transparent" BorderThickness="1" BorderBrush="#E0E0E0"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Key}" FontWeight="SemiBold" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding Name}" Foreground="Gray" />
                            <TextBlock Text=" - " Foreground="Gray" />
                            <TextBlock Text="{Binding Id}" Foreground="Gray" FontSize="11" />
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Separator -->
        <Separator Margin="0,16,0,12" />

        <!-- Default Project ID (optional) -->
        <TextBlock Text="Default Project ID (optional)" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Text="If set, new issues will be added to this project. Leave empty to create issues without a project."
                   Foreground="Gray" FontSize="12" Margin="0,0,0,6" TextWrapping="Wrap" />
        <TextBox x:Name="ProjectIdBox" TextChanged="OnProjectIdChanged" />
    </StackPanel>
</UserControl>

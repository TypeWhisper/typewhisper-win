<UserControl x:Class="TypeWhisper.Windows.Controls.Overlay.EdgeDockIndicatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters"
             xmlns:models="clr-namespace:TypeWhisper.Core.Models;assembly=TypeWhisper.Core"
             xmlns:overlay="clr-namespace:TypeWhisper.Windows.Controls.Overlay">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:EdgeDockStatusDockConverter x:Key="EdgeDockStatusDock"/>
    </UserControl.Resources>

    <Border x:Name="DockBorder"
            Background="#E6101824"
            BorderBrush="#2B7EC8FF"
            BorderThickness="1"
            HorizontalAlignment="Center"
            MinWidth="360"
            MaxWidth="620"
            Padding="9,6">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="0,0,9,9"/>
                <Setter Property="Margin" Value="0"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding OverlayPosition}" Value="{x:Static models:OverlayPosition.Bottom}">
                        <Setter Property="CornerRadius" Value="9,9,0,0"/>
                        <Setter Property="Margin" Value="0"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="16" Opacity="0.42" ShadowDepth="0"/>
        </Border.Effect>

        <DockPanel LastChildFill="False">
            <Grid MinHeight="28"
                  DockPanel.Dock="{Binding OverlayPosition, Converter={StaticResource EdgeDockStatusDock}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <overlay:OverlayWidgetHost
                    Grid.Column="0"
                    WidgetType="{Binding LeftWidget}"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding StatusText}"
                           Foreground="#D8FFFFFF"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>

                <overlay:OverlayWidgetHost
                    Grid.Column="2"
                    WidgetType="{Binding RightWidget}"
                    VerticalAlignment="Center"
                    Margin="8,0,0,0"/>
            </Grid>

            <Border x:Name="PartialPreviewBorder"
                    ClipToBounds="True"
                    Height="0"
                    Opacity="0"
                    Margin="0"
                    DockPanel.Dock="{Binding OverlayPosition, Converter={StaticResource EdgeDockStatusDock}}"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="PartialPreviewTransform"/>
                </Border.RenderTransform>
                <ScrollViewer x:Name="PartialPreviewScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <TextBlock x:Name="PartialTextBlock"
                               Text="{Binding PartialText, NotifyOnTargetUpdated=True}"
                               TargetUpdated="OnPartialTextTargetUpdated"
                               TextWrapping="Wrap"
                               MaxWidth="560"
                               Foreground="#92FFFFFF"
                               FontSize="{Binding LiveTranscriptionFontSize}"
                               TextAlignment="Center"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="PartialTextTransform"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </ScrollViewer>
            </Border>

            <Border CornerRadius="8"
                    Padding="12,6"
                    Margin="0,4,0,0"
                    DockPanel.Dock="{Binding OverlayPosition, Converter={StaticResource EdgeDockStatusDock}}"
                    Visibility="{Binding ShowInlineFeedback, Converter={StaticResource BoolToVis}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#1AFF4444"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FeedbackIsError}" Value="False">
                                <Setter Property="Background" Value="#1A33D17A"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding FeedbackText}"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FF6666"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FeedbackIsError}" Value="False">
                                    <Setter Property="Foreground" Value="#66E3A2"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </DockPanel>
    </Border>
</UserControl>

<UserControl x:Class="TypeWhisper.Windows.Controls.Overlay.CompactBadgeIndicatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters"
             xmlns:overlay="clr-namespace:TypeWhisper.Windows.Controls.Overlay">
    <UserControl.Resources>
        <conv:AudioLevelScaleConverter x:Key="AudioLevelScale"/>
    </UserControl.Resources>

    <Border CornerRadius="18"
            Background="#F0181818"
            BorderBrush="#2AFFFFFF"
            BorderThickness="1"
            HorizontalAlignment="Center"
            MinWidth="34"
            MinHeight="34"
            Padding="10"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform ScaleX="{Binding AudioLevel, Converter={StaticResource AudioLevelScale}, ConverterParameter=0.026}"
                            ScaleY="{Binding AudioLevel, Converter={StaticResource AudioLevelScale}, ConverterParameter=0.026}"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.46" ShadowDepth="0"/>
        </Border.Effect>

        <overlay:IndicatorWidget
            HorizontalAlignment="Center"
            VerticalAlignment="Center"/>
    </Border>
</UserControl>

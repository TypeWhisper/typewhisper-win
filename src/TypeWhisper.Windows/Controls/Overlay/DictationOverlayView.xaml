<UserControl x:Class="TypeWhisper.Windows.Controls.Overlay.DictationOverlayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters"
             xmlns:models="clr-namespace:TypeWhisper.Core.Models;assembly=TypeWhisper.Core"
             xmlns:overlay="clr-namespace:TypeWhisper.Windows.Controls.Overlay">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:EdgeDockStatusDockConverter x:Key="EdgeDockStatusDock"/>
    </UserControl.Resources>

    <Border x:Name="IslandBorder"
            CornerRadius="17"
            Background="#E6121822"
            BorderBrush="#22507BAA"
            BorderThickness="1"
            HorizontalAlignment="Center"
            MinWidth="172"
            Padding="10,7">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="12" Opacity="0.5" ShadowDepth="0"/>
        </Border.Effect>

        <DockPanel LastChildFill="False">
            <Grid MinHeight="26"
                  DockPanel.Dock="{Binding OverlayPosition, Converter={StaticResource EdgeDockStatusDock}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <overlay:OverlayWidgetHost
                    Grid.Column="0"
                    WidgetType="{Binding LeftWidget}"
                    VerticalAlignment="Center"
                    Margin="0,0,9,0"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding StatusText}"
                           Foreground="#CCFFFFFF"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>

                <overlay:OverlayWidgetHost
                    Grid.Column="2"
                    WidgetType="{Binding RightWidget}"
                    VerticalAlignment="Center"
                    Margin="9,0,0,0"/>
            </Grid>

            <Border x:Name="DownwardPartialPreview"
                    CornerRadius="0"
                    Background="Transparent"
                    ClipToBounds="True"
                    DockPanel.Dock="{Binding OverlayPosition, Converter={StaticResource EdgeDockStatusDock}}"
                    Height="0"
                    Opacity="0"
                    Padding="0"
                    RenderTransformOrigin="0.5,0">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="PartialPreviewTransform" Y="-5"/>
                </Border.RenderTransform>
                <TextBlock x:Name="PartialTextBlock"
                           Text="{Binding PartialText}"
                           Foreground="#8EFFFFFF"
                           FontSize="{Binding LiveTranscriptionFontSize}"
                           TextWrapping="Wrap"
                           RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="PartialTextTransform"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Border>

            <Border CornerRadius="0,0,22,22"
                    Padding="16,6,16,2"
                    Margin="0,6,0,-4"
                    DockPanel.Dock="{Binding OverlayPosition, Converter={StaticResource EdgeDockStatusDock}}"
                    Visibility="{Binding ShowInlineFeedback, Converter={StaticResource BoolToVis}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#1AFF4444"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FeedbackIsError}" Value="False">
                                <Setter Property="Background" Value="#1A33D17A"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding FeedbackText}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#FF6666"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FeedbackIsError}" Value="False">
                                        <Setter Property="Foreground" Value="#66E3A2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Content="{Binding FeedbackActionText}"
                            Command="{Binding FeedbackActionCommand}"
                            Visibility="{Binding ShowFeedbackAction, Converter={StaticResource BoolToVis}}"
                            FontSize="11"
                            Padding="8,1"
                            Margin="8,0,0,0"
                            MinWidth="0"
                            VerticalAlignment="Center"
                            Foreground="#FFFFFFFF"
                            Background="#22FFFFFF"
                            BorderBrush="#33FFFFFF"/>
                </StackPanel>
            </Border>
        </DockPanel>
    </Border>
</UserControl>

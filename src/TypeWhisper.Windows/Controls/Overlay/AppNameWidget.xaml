<UserControl x:Class="TypeWhisper.Windows.Controls.Overlay.AppNameWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters">
    <UserControl.Resources>
        <conv:NonEmptyToVisibilityConverter x:Key="NonEmptyToVis"/>
    </UserControl.Resources>
    <Border Background="#16FFFFFF" BorderBrush="#1FFFFFFF" BorderThickness="1" CornerRadius="7" Padding="6,2"
            Visibility="{Binding ActiveProcessName, Converter={StaticResource NonEmptyToVis}}">
        <TextBlock Text="{Binding ActiveProcessName, FallbackValue='App', TargetNullValue='App'}"
                   Foreground="#D9FFFFFF" FontSize="10" FontWeight="Medium"
                   MaxWidth="80" TextTrimming="CharacterEllipsis"
                   VerticalAlignment="Center"/>
    </Border>
</UserControl>

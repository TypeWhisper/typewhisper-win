<UserControl x:Class="TypeWhisper.Windows.Controls.Overlay.ProfileWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters"
             xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization">
    <UserControl.Resources>
        <conv:NonEmptyToVisibilityConverter x:Key="NonEmptyToVis"/>
        <conv:InvertBoolToVisibilityConverter x:Key="InvertBoolToVis"/>
    </UserControl.Resources>
    <Grid>
        <!-- Active profile -->
        <Border Background="#1F6FB6FF" BorderBrush="#306FB6FF" BorderThickness="1" CornerRadius="7" Padding="6,2"
                Visibility="{Binding ActiveWorkflowName, Converter={StaticResource NonEmptyToVis}}">
            <TextBlock Text="{Binding ActiveWorkflowName}"
                       Foreground="#D9FFFFFF" FontSize="10" FontWeight="Medium"
                       MaxWidth="80" TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center"/>
        </Border>
        <!-- No profile -->
        <Border Background="#16FFFFFF" BorderBrush="#1FFFFFFF" BorderThickness="1" CornerRadius="7" Padding="6,2">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ActiveWorkflowName, Converter={StaticResource NonEmptyToVis}}" Value="Visible">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{loc:Str Workflows.NoActiveWorkflow}"
                       Foreground="#99FFFFFF" FontSize="10"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>

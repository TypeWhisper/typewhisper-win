<UserControl x:Class="TypeWhisper.Windows.Controls.Overlay.IndicatorWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters"
             xmlns:vm="clr-namespace:TypeWhisper.Windows.ViewModels">
    <UserControl.Resources>
        <conv:AudioLevelScaleConverter x:Key="AudioLevelScale"/>
    </UserControl.Resources>
    <Ellipse Width="10"
             Height="10"
             VerticalAlignment="Center"
             RenderTransformOrigin="0.5,0.5">
        <Ellipse.RenderTransform>
            <ScaleTransform ScaleX="{Binding AudioLevel, Converter={StaticResource AudioLevelScale}, ConverterParameter=0.32}"
                            ScaleY="{Binding AudioLevel, Converter={StaticResource AudioLevelScale}, ConverterParameter=0.32}"/>
        </Ellipse.RenderTransform>
        <Ellipse.Style>
            <Style TargetType="Ellipse">
                <Setter Property="Fill" Value="#888"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding State}" Value="{x:Static vm:DictationState.Recording}">
                        <Setter Property="Fill" Value="#FF4444"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding State}" Value="{x:Static vm:DictationState.Processing}">
                        <Setter Property="Fill" Value="#FFaa00"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding State}" Value="{x:Static vm:DictationState.Inserting}">
                        <Setter Property="Fill" Value="#44cc44"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding State}" Value="{x:Static vm:DictationState.Error}">
                        <Setter Property="Fill" Value="#FF0000"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Ellipse.Style>
    </Ellipse>
</UserControl>

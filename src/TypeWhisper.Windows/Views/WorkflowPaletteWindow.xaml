<Window x:Class="TypeWhisper.Windows.Views.WorkflowPaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization"
        Title="{loc:Str WorkflowPalette.Title}"
        Width="560"
        Height="420"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Deactivated="OnDeactivated"
        Loaded="OnLoaded"
        PreviewKeyDown="OnPreviewKeyDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="8"
            Background="#F0141D29"
            BorderBrush="#35FFFFFF"
            BorderThickness="1"
            Padding="14">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="24" Opacity="0.45" ShadowDepth="0"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{loc:Str WorkflowPalette.Title}"
                       Style="{StaticResource SettingsGroupTitleStyle}"
                       Margin="2,0,0,10"/>

            <Border Grid.Row="1"
                    Background="#111B27"
                    BorderBrush="#22364D"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="{loc:Str WorkflowPalette.SourceText}"
                               Foreground="{StaticResource HintBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding SourceTextPreview}"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="12.5"
                               TextWrapping="Wrap"
                               MaxHeight="54"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <TextBox x:Name="SearchBox"
                     Grid.Row="2"
                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputTextBoxStyle}"
                     Margin="0,0,0,10"/>

            <Grid Grid.Row="3">
                <ListBox x:Name="WorkflowsList"
                         ItemsSource="{Binding FilteredWorkflows}"
                         SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource SettingsScrollBarStyle}"/>
                    </ListBox.Resources>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,4"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="RowChrome"
                                                CornerRadius="6"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="1">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="RowChrome" Property="Background" Value="#243A5A"/>
                                                <Setter TargetName="RowChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="RowChrome" Property="Background" Value="#1D2B3E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8"
                                    Background="Transparent"
                                    MouseLeftButtonUp="Workflow_MouseLeftButtonUp">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Width="34"
                                            Height="34"
                                            CornerRadius="9"
                                            Background="#14337FD8"
                                            BorderBrush="#225E9FF2"
                                            BorderThickness="1"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="{Binding IconGlyph}"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontSize="15"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{StaticResource TextBrush}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Subtitle}"
                                                   Foreground="{StaticResource HintBrush}"
                                                   FontSize="11"
                                                   Margin="0,3,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="{loc:Str WorkflowPalette.Empty}"
                           Foreground="{StaticResource HintBrush}"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasFilteredWorkflows}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Grid>
    </Border>
</Window>

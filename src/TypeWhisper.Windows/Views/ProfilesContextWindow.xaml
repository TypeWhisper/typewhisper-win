<ui:FluentWindow x:Class="TypeWhisper.Windows.Views.ProfilesContextWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters"
                 xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization"
                 Title="{loc:Str Profiles.LiveContextWindowTitle}"
                 Width="420"
                 Height="290"
                 MinWidth="380"
                 MinHeight="250"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="CanResizeWithGrip"
                 ShowInTaskbar="False"
                 Topmost="True"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="None"
                 Background="#0E131B"
                 Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <conv:InvertBoolToVisibilityConverter x:Key="InvertBoolToVis"/>
            <Style x:Key="MatchBadgeBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="#1AD95D66"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding HasMatchedProfile}" Value="True">
                        <Setter Property="Background" Value="#1739B980"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="MatchBadgeTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding HasMatchedProfile}" Value="True">
                        <Setter Property="Foreground" Value="{StaticResource ActiveIndicatorBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="InspectorValueStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="FontSize" Value="12.5"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            </Style>
            <Style x:Key="InspectorLinkStyle" TargetType="Button" BasedOn="{StaticResource LinkButtonStyle}">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="FontSize" Value="11.5"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <ui:TitleBar Grid.Row="0"
                         Title=""
                         ShowMaximize="False"
                         Margin="14,8,14,0"/>

            <Grid Grid.Row="1" Margin="18,8,18,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="{Binding SelectedProfileDisplayName}" Style="{StaticResource SettingsGroupTitleStyle}" FontSize="16" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding SelectedProfileSummary}" Style="{StaticResource HintStyle}" Margin="0"/>
                    </StackPanel>
                    <Border Grid.Column="1"
                            Style="{StaticResource MatchBadgeBorderStyle}"
                            Padding="10,6"
                            CornerRadius="999"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding MatchStatusText}" Style="{StaticResource MatchBadgeTextStyle}" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                </Grid>

                <TextBlock Grid.Row="1"
                           Text="{loc:Str Profiles.LiveContextNoProfileHint}"
                           Style="{StaticResource HintStyle}"
                           Margin="0,0,0,14"
                           Visibility="{Binding HasSelectedProfile, Converter={StaticResource InvertBoolToVis}}"/>

                <Border Grid.Row="2" Height="1" Background="#16FFFFFF"/>

                <Grid Grid.Row="3" Margin="0,12,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="{loc:Str Profiles.Apps}" Style="{StaticResource SettingsRowLabelStyle}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding CurrentProcessName}" Style="{StaticResource InspectorValueStyle}"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="{loc:Str Profiles.UseCurrentApp}"
                            Style="{StaticResource InspectorLinkStyle}"
                            Command="{Binding AddCurrentProcessRuleCommand}"
                            IsEnabled="{Binding HasSelectedProfile}"
                            Visibility="{Binding HasCurrentProcess, Converter={StaticResource BoolToVis}}"
                            VerticalAlignment="Center"/>
                </Grid>

                <Border Grid.Row="4" Height="1" Background="#16FFFFFF"/>

                <Grid Grid.Row="5" Margin="0,12,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="{loc:Str Profiles.Domain}" Style="{StaticResource SettingsRowLabelStyle}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding CurrentUrlPattern}"
                                   Style="{StaticResource InspectorValueStyle}"
                                   Foreground="#88FFCC"
                                   Visibility="{Binding HasCurrentUrl, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="{Binding CurrentWindowTitle}"
                                   Style="{StaticResource HintStyle}"
                                   Margin="0,6,0,0"
                                   Visibility="{Binding HasCurrentWindowTitle, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="{loc:Str Profiles.NoBrowserUrl}"
                                   Style="{StaticResource HintStyle}"
                                   Margin="0,2,0,0"
                                   Visibility="{Binding HasCurrentUrl, Converter={StaticResource InvertBoolToVis}}"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="{loc:Str Profiles.UseCurrentDomain}"
                            Style="{StaticResource InspectorLinkStyle}"
                            Command="{Binding AddCurrentUrlRuleCommand}"
                            IsEnabled="{Binding HasSelectedProfile}"
                            Visibility="{Binding HasCurrentUrl, Converter={StaticResource BoolToVis}}"
                            VerticalAlignment="Top"/>
                </Grid>

                <Border Grid.Row="6" Height="1" Background="#16FFFFFF"/>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>

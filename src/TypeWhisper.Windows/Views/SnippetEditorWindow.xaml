<Window x:Class="TypeWhisper.Windows.Views.SnippetEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization"
        Title="{Binding EditorTitle}"
        Width="560" Height="640"
        MinWidth="520" MinHeight="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Style="{StaticResource WizardShellStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,18">
                <TextBlock Text="{Binding EditorTitle}" Style="{StaticResource SettingsGroupTitleStyle}" FontSize="22" Margin="0,0,0,4"/>
                <TextBlock Text="{loc:Str SnippetEditor.Subtitle}" Style="{StaticResource PageSubtitleStyle}" Margin="0"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{loc:Str SnippetEditor.SnippetGroup}" Style="{StaticResource SettingsGroupTitleStyle}"/>
                    <Border Style="{StaticResource SettingsGroupPanelStyle}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="{loc:Str SnippetEditor.Trigger}" Style="{StaticResource SettingsRowLabelStyle}" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding EditTrigger, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SettingsCompactTextBoxStyle}"
                                             FontFamily="Consolas"/>
                                    <TextBlock Text="{loc:Str SnippetEditor.TriggerHint}" Style="{StaticResource HintStyle}" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Height="1" Background="#16FFFFFF"/>

                            <Border Style="{StaticResource SettingsRowBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="{loc:Str SnippetEditor.Replacement}" Style="{StaticResource SettingsRowLabelStyle}" Margin="0,0,0,8"/>
                                    <TextBox x:Name="ReplacementBox"
                                             Text="{Binding EditReplacement, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource WizardTrialTextBoxStyle}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             VerticalContentAlignment="Top"
                                             MinHeight="140"/>
                                </StackPanel>
                            </Border>

                            <Border Height="1" Background="#16FFFFFF"/>

                            <Border Style="{StaticResource SettingsRowBorderStyle}">
                                <CheckBox IsChecked="{Binding EditCaseSensitive}"
                                          Style="{StaticResource InputCheckBoxStyle}"
                                          Content="{loc:Str SnippetEditor.CaseSensitive}"/>
                            </Border>

                            <Border Height="1" Background="#16FFFFFF"/>

                            <Border Style="{StaticResource SettingsRowBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="{loc:Str SnippetEditor.Tags}" Style="{StaticResource SettingsRowLabelStyle}" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding EditTags, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SettingsCompactTextBoxStyle}"/>
                                    <TextBlock Text="{loc:Str SnippetEditor.TagsHint}" Style="{StaticResource HintStyle}" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{loc:Str SnippetEditor.PlaceholderGroup}" Style="{StaticResource SettingsGroupTitleStyle}" Margin="0,4,0,8"/>
                    <Border Style="{StaticResource SettingsGroupPanelStyle}">
                        <StackPanel Margin="18,16">
                            <TextBlock Text="{loc:Str SnippetEditor.Placeholders}" Style="{StaticResource HintStyle}" Margin="0,0,0,10"/>
                            <WrapPanel>
                                <Button Content="{}{date}" Click="InsertPlaceholder_Click" Tag="{}{date}"
                                        Style="{StaticResource SecondaryButtonStyle}" Padding="9,5" FontSize="11" Margin="0,0,6,6"/>
                                <Button Content="{}{time}" Click="InsertPlaceholder_Click" Tag="{}{time}"
                                        Style="{StaticResource SecondaryButtonStyle}" Padding="9,5" FontSize="11" Margin="0,0,6,6"/>
                                <Button Content="{}{datetime}" Click="InsertPlaceholder_Click" Tag="{}{datetime}"
                                        Style="{StaticResource SecondaryButtonStyle}" Padding="9,5" FontSize="11" Margin="0,0,6,6"/>
                                <Button Content="{}{clipboard}" Click="InsertPlaceholder_Click" Tag="{}{clipboard}"
                                        Style="{StaticResource SecondaryButtonStyle}" Padding="9,5" FontSize="11" Margin="0,0,6,6"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" Content="{loc:Str SnippetEditor.Cancel}" IsCancel="True"
                        Style="{StaticResource SecondaryButtonStyle}" Padding="16,8" Margin="0,0,8,0"
                        Click="Cancel_Click"/>
                <Button Grid.Column="2" Content="{loc:Str SnippetEditor.Save}" IsDefault="True"
                        Style="{StaticResource PrimaryButtonStyle}" Padding="16,8"
                        Click="Save_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>

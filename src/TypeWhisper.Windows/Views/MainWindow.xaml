<Window x:Class="TypeWhisper.Windows.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:TypeWhisper.Core.Models;assembly=TypeWhisper.Core"
        xmlns:overlay="clr-namespace:TypeWhisper.Windows.Controls.Overlay"
        Title="TypeWhisper"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Focusable="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        RenderOptions.ClearTypeHint="Enabled"
        Loaded="OnLoaded"
        SizeChanged="OnSizeChanged">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid x:Name="OverlayChrome"
          UseLayoutRounding="True"
          SnapsToDevicePixels="True"
          Visibility="{Binding HasOverlayContentVisible, Converter={StaticResource BoolToVis}}">
        <Grid.Style>
            <Style TargetType="{x:Type Grid}">
                <Setter Property="Margin" Value="8"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IndicatorStyle}" Value="{x:Static models:IndicatorStyle.EdgeDock}">
                        <Setter Property="Margin" Value="0"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>

        <overlay:IndicatorStyleHost
            Visibility="{Binding IsOverlayVisible, Converter={StaticResource BoolToVis}}"/>

        <overlay:DetachedFeedbackView
            Visibility="{Binding ShowDetachedFeedback, Converter={StaticResource BoolToVis}}"/>
    </Grid>
</Window>

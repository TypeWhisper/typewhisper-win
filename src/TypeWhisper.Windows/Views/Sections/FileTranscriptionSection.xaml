<UserControl x:Class="TypeWhisper.Windows.Views.Sections.FileTranscriptionSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TypeWhisper.Windows.ViewModels"
             xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,22,28,28" MaxWidth="980">
            <Border AllowDrop="True"
                    Drop="OnDrop"
                    DragOver="OnDragOver"
                    Background="Transparent"
                    BorderBrush="#4B545E"
                    BorderThickness="2"
                    CornerRadius="18"
                    Padding="28">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{loc:Str FileTranscription.DragHint}"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{loc:Str FileTranscription.Or}"
                               Foreground="{StaticResource HintBrush}"
                               Margin="0,10,0,10"
                               HorizontalAlignment="Center"/>
                    <Button Content="{loc:Str FileTranscription.SelectFile}"
                            Click="OnSelectFile"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="18,8"
                            HorizontalAlignment="Center"/>
                    <TextBlock Text="{loc:Str FileTranscription.Formats}"
                               Foreground="{StaticResource HintBrush}"
                               FontSize="12"
                               Margin="0,14,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsSectionDividerStyle}"/>

            <StackPanel Style="{StaticResource SettingsSectionStyle}">
                <TextBlock Text="{loc:Str FileTranscription.Importer}" Style="{StaticResource SettingsGroupTitleStyle}"/>
                <Border Style="{StaticResource SettingsGroupPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding FileTranscription.StatusText}"
                                           Style="{StaticResource SectionHeaderStyle}"
                                           FontSize="15"
                                           Margin="0"/>
                                <Button Grid.Column="1"
                                        Content="{loc:Str FileTranscription.Cancel}"
                                        Command="{Binding FileTranscription.CancelCommand}"
                                        Visibility="{Binding FileTranscription.IsProcessing, Converter={StaticResource BoolToVis}}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="14,8"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Background="#18FFFFFF"/>

                        <Border Grid.Row="2" Style="{StaticResource SettingsRowBorderStyle}">
                            <ProgressBar IsIndeterminate="{Binding FileTranscription.IsProcessing}"
                                         Height="4"
                                         Visibility="{Binding FileTranscription.IsProcessing, Converter={StaticResource BoolToVis}}"/>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Style="{StaticResource SettingsSectionStyle}">
                <TextBlock Text="{loc:Str FileTranscription.Result}" Style="{StaticResource SettingsGroupTitleStyle}"/>
                <Border Style="{StaticResource SettingsGroupPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource SettingsRowBorderStyle}">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            Visibility="{Binding FileTranscription.HasResult, Converter={StaticResource BoolToVis}}">
                                    <Button Content="{loc:Str FileTranscription.Copy}" Command="{Binding FileTranscription.CopyToClipboardCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                                    <Button Content="{loc:Str FileTranscription.TextExportShort}" Command="{Binding FileTranscription.ExportTextCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                                    <Button Content="SRT" Command="{Binding FileTranscription.ExportSrtCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                                    <Button Content="WebVTT" Command="{Binding FileTranscription.ExportWebVttCommand}" Style="{StaticResource SecondaryButtonStyle}"/>
                                </StackPanel>
                                <TextBlock Style="{StaticResource HintStyle}" Margin="0">
                                    <Run Text="{loc:Str FileTranscription.DetectedLanguage}"/>
                                    <Run Text="{Binding FileTranscription.DetectedLanguage}"/>
                                </TextBlock>
                            </DockPanel>
                        </Border>

                        <Border Grid.Row="1" Background="#18FFFFFF"/>

                        <Border Grid.Row="2" Padding="18">
                            <TextBox Text="{Binding FileTranscription.ResultText, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="260"
                                     Style="{StaticResource InputTextBoxStyle}"/>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>

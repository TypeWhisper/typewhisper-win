<UserControl x:Class="TypeWhisper.Windows.Views.Sections.PluginsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:TypeWhisper.Windows.ViewModels"
             xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters"
             xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <conv:NonEmptyToVisibilityConverter x:Key="NonEmptyToVis"/>
            <conv:InstallStateToVisibilityConverter x:Key="InstallStateToVis"/>
            <conv:InvertBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
            <conv:InvertBoolConverter x:Key="InvertBool"/>
            <conv:StringToBrushConverter x:Key="StringToBrush"/>

            <Style x:Key="TabButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource HintBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,0,2"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ActiveTabButtonStyle" TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            </Style>

            <Style x:Key="MarketplaceCategoryTabButtonStyle" TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{StaticResource HintBrush}"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource SettingsSummaryBarStyle}">
            <StackPanel>
                <TextBlock Text="{loc:Str Plugins.Title}" Style="{StaticResource SettingsGroupTitleStyle}" Margin="0,0,0,4"/>
                <TextBlock Text="{loc:Str Plugins.Subtitle}" Style="{StaticResource PageSubtitleStyle}" Margin="0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource SettingsActionBarStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Button x:Name="TabInstalled" Style="{StaticResource ActiveTabButtonStyle}" Click="OnInstalledTabClick">
                        <TextBlock><Run Text="&#x1F9E9;  "/><Run Text="{Binding Source={x:Static loc:Loc.Instance}, Path=[Plugins.Installed], Mode=OneWay}"/></TextBlock>
                    </Button>
                    <Button x:Name="TabMarketplace" Style="{StaticResource TabButtonStyle}" Click="OnMarketplaceTabClick">
                        <TextBlock><Run Text="&#x1F6D2;  "/><Run Text="{Binding Source={x:Static loc:Loc.Instance}, Path=[Plugins.Marketplace], Mode=OneWay}"/></TextBlock>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <ScrollViewer x:Name="InstalledPanel" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource SettingsFilterRowStyle}">
                        <StackPanel>
                            <TextBlock Text="{Binding Plugins.InstalledSummaryText}" Style="{StaticResource PageSubtitleStyle}" Margin="0"/>
                            <TextBlock Text="{Binding Plugins.PluginUpdateSummaryText}"
                                       Foreground="{StaticResource WarningBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="0,4,0,0"
                                       Visibility="{Binding Plugins.HasAvailablePluginUpdates, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="EmptyState"
                            Visibility="Collapsed"
                            Style="{StaticResource SettingsSummaryBarStyle}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#x1F9E9;" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="{loc:Str Plugins.NoPlugins}" Foreground="{StaticResource TextBrush}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Text="{loc:Str Plugins.NoPluginsHint}" Foreground="{StaticResource HintBrush}" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Plugins.Plugins}" HorizontalContentAlignment="Stretch">
                        <ItemsControl.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource SettingsGroupTitleStyle}" Margin="0,6,0,8"/>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ItemsControl.GroupStyle>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:PluginItemViewModel}">
                                <ui:CardExpander IsExpanded="{Binding IsExpanded, Mode=TwoWay}" Margin="0,0,0,10">
                                    <ui:CardExpander.Header>
                                        <Grid Margin="0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0" Background="{Binding IconGradientStart, Converter={StaticResource StringToBrush}}">
                                                <Grid>
                                                    <Image Source="{Binding LogoPath}"
                                                           Width="28"
                                                           Height="28"
                                                           Stretch="Uniform"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding HasLogo, Converter={StaticResource BoolToVis}}"/>
                                                    <TextBlock Text="{Binding IconEmoji}"
                                                               FontSize="18"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding HasLogo, Converter={StaticResource InverseBoolToVis}}"/>
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="0,0,14,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Version, StringFormat='  v{0}'}" Foreground="{StaticResource HintBrush}" FontSize="12" Margin="4,0,0,0"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" Foreground="{StaticResource HintBrush}" FontSize="12" TextTrimming="CharacterEllipsis" MaxHeight="18" Margin="0,4,0,0"/>
                                                <WrapPanel Margin="0,7,0,0">
                                                    <ItemsControl ItemsSource="{Binding CategoryDescriptors}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="{x:Type vm:PluginMarketplaceCategoryDescriptor}">
                                                                <Border Style="{StaticResource BadgeStyle}" Margin="0,0,6,0">
                                                                    <TextBlock Text="{Binding DisplayName}" Foreground="#D6DEE9" FontSize="10"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <Border Style="{StaticResource BadgeStyle}" Margin="0,0,6,0">
                                                        <TextBlock Text="{Binding LocationBadge}" Foreground="#D6DEE9" FontSize="10"/>
                                                    </Border>
                                                    <Border Style="{StaticResource BadgeStyle}" Margin="0,0,6,0">
                                                        <TextBlock Text="{Binding StatusLabel}" Foreground="#D6DEE9" FontSize="10"/>
                                                    </Border>
                                                    <Border Style="{StaticResource BadgeStyle}"
                                                            Visibility="{Binding HasUpdateAvailable, Converter={StaticResource BoolToVis}}"
                                                            Margin="0,0,6,0">
                                                        <TextBlock Foreground="{StaticResource WarningBrush}" FontSize="10">
                                                            <Run Text="{Binding Source={x:Static loc:Loc.Instance}, Path=[Plugins.UpdateAvailablePrefix], Mode=OneWay}"/>
                                                            <Run Text="{Binding AvailableUpdateVersion, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </Border>
                                                    <Border Style="{StaticResource BadgeStyle}"
                                                            Visibility="{Binding IsUpdatePendingRestart, Converter={StaticResource BoolToVis}}"
                                                            Margin="0,0,6,0">
                                                        <TextBlock Foreground="{StaticResource WarningBrush}" FontSize="10">
                                                            <Run Text="&#x21BB; "/><Run Text="{Binding Source={x:Static loc:Loc.Instance}, Path=[Plugins.RestartRequiredBadge], Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </Border>
                                                </WrapPanel>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <ui:Button Appearance="Secondary"
                                                           Content="{loc:Str Plugins.Update}"
                                                           Command="{Binding UpdateRegistryPluginCommand}"
                                                           Visibility="{Binding HasUpdateAvailable, Converter={StaticResource BoolToVis}}"
                                                           Margin="0,0,8,0"/>
                                                <ui:Button Appearance="Secondary"
                                                           ToolTip="{loc:Str Plugins.Uninstall}"
                                                           Command="{Binding UninstallCommand}"
                                                           Padding="6,4"
                                                           Margin="0,0,8,0">
                                                    <ui:SymbolIcon Symbol="Delete24"/>
                                                </ui:Button>
                                                <ui:ToggleSwitch IsChecked="{Binding IsEnabled}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </ui:CardExpander.Header>

                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock Text="{Binding Description}" Foreground="{StaticResource HintBrush}" FontSize="12" TextWrapping="Wrap" Visibility="{Binding Description, Converter={StaticResource NonEmptyToVis}}"/>
                                        <WrapPanel Margin="0,8,0,0">
                                            <Border Style="{StaticResource BadgeStyle}" Visibility="{Binding IsTranscriptionProvider, Converter={StaticResource BoolToVis}}" Margin="0,0,6,6">
                                                <TextBlock Foreground="#D6DEE9" FontSize="10"><Run Text="&#x1F3A4; "/><Run Text="{Binding Source={x:Static loc:Loc.Instance}, Path=[Plugins.Transcription], Mode=OneWay}"/></TextBlock>
                                            </Border>
                                            <Border Style="{StaticResource BadgeStyle}" Visibility="{Binding IsLlmProvider, Converter={StaticResource BoolToVis}}" Margin="0,0,6,6">
                                                <TextBlock Foreground="#D6DEE9" FontSize="10"><Run Text="&#x1F916; "/><Run Text="{Binding Source={x:Static loc:Loc.Instance}, Path=[Plugins.Llm], Mode=OneWay}"/></TextBlock>
                                            </Border>
                                            <Border Style="{StaticResource BadgeStyle}" Visibility="{Binding IsTtsProvider, Converter={StaticResource BoolToVis}}" Margin="0,0,6,6">
                                                <TextBlock Foreground="#D6DEE9" FontSize="10"><Run Text="&#x1F50A; "/><Run Text="{Binding Source={x:Static loc:Loc.Instance}, Path=[Plugins.Tts], Mode=OneWay}"/></TextBlock>
                                            </Border>
                                            <Border Style="{StaticResource BadgeStyle}" Visibility="{Binding IsPostProcessor, Converter={StaticResource BoolToVis}}" Margin="0,0,6,6">
                                                <TextBlock Foreground="#D6DEE9" FontSize="10"><Run Text="&#x2699; "/><Run Text="{Binding Source={x:Static loc:Loc.Instance}, Path=[Plugins.PostProcessing], Mode=OneWay}"/></TextBlock>
                                            </Border>
                                            <Border Style="{StaticResource BadgeStyle}" Visibility="{Binding IsActionProvider, Converter={StaticResource BoolToVis}}" Margin="0,0,6,6">
                                                <TextBlock Foreground="#D6DEE9" FontSize="10"><Run Text="&#x26A1; "/><Run Text="{Binding Source={x:Static loc:Loc.Instance}, Path=[Plugins.Action], Mode=OneWay}"/></TextBlock>
                                            </Border>
                                        </WrapPanel>
                                        <ContentControl Content="{Binding SettingsView}" Margin="0,10,0,0" Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                </ui:CardExpander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="MarketplacePanel"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="Collapsed"
                          PreviewMouseWheel="OnMarketplacePanelPreviewMouseWheel">
                <StackPanel>
                    <Border Style="{StaticResource SettingsFilterRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="{Binding Plugins.MarketplaceCategorySummaryText}" Style="{StaticResource PageSubtitleStyle}" Margin="0,0,0,4"/>
                                <TextBlock Text="{loc:Str Plugins.MarketplaceDescription}" Style="{StaticResource HintStyle}" Margin="0"/>
                                <WrapPanel Margin="0,10,0,0">
                                    <ui:Button Appearance="Secondary"
                                               Content="{loc:Str Plugins.AllFunctions}"
                                               Command="{Binding Plugins.ClearMarketplaceCapabilityFiltersCommand}"
                                               Visibility="{Binding Plugins.HasActiveMarketplaceCapabilityFilters, Converter={StaticResource BoolToVis}}"
                                               Margin="0,0,10,6"/>
                                    <ItemsControl ItemsSource="{Binding Plugins.MarketplaceCapabilityFilters}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:MarketplaceCapabilityFilterViewModel}">
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=OneWay}"
                                                          Command="{Binding DataContext.Plugins.ToggleMarketplaceCapabilityFilterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding Key}"
                                                          Style="{StaticResource InputCheckBoxStyle}"
                                                          Margin="0,0,12,6">
                                                    <TextBlock Foreground="{StaticResource LabelBrush}" FontSize="12">
                                                        <Run Text="{Binding DisplayName, Mode=OneWay}"/>
                                                        <Run Text=" "/>
                                                        <Run Text="{Binding Count, StringFormat='({0})', Mode=OneWay}"/>
                                                    </TextBlock>
                                                </CheckBox>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </WrapPanel>
                            </StackPanel>
                            <ui:Button Grid.Column="1"
                                       Appearance="Secondary"
                                       Content="{loc:Str Plugins.MarketplaceRefresh}"
                                       Command="{Binding Plugins.RefreshRegistryCommand}"
                                       Icon="{ui:SymbolIcon ArrowSync24}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Visibility="{Binding Plugins.IsLoadingRegistry, Converter={StaticResource BoolToVis}}"
                            Style="{StaticResource SettingsSummaryBarStyle}">
                        <StackPanel HorizontalAlignment="Center">
                            <ui:ProgressRing IsIndeterminate="True" Width="32" Height="32" Margin="0,0,0,8"/>
                            <TextBlock Text="{loc:Str Plugins.MarketplaceLoading}" Foreground="{StaticResource HintBrush}" FontSize="13" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsGroupPanelStyle}"
                            Visibility="{Binding Plugins.IsLoadingRegistry, Converter={StaticResource InverseBoolToVis}}">
                        <ItemsControl ItemsSource="{Binding Plugins.FilteredMarketplacePlugins}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:RegistryPluginItemViewModel}">
                                    <Border Style="{StaticResource SettingsCollectionRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0" Background="{Binding IconGradientStart, Converter={StaticResource StringToBrush}}">
                                                <Grid>
                                                    <Image Source="{Binding LogoPath}"
                                                           Width="28"
                                                           Height="28"
                                                           Stretch="Uniform"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding HasLogo, Converter={StaticResource BoolToVis}}"/>
                                                    <TextBlock Text="{Binding IconEmoji}"
                                                               FontSize="18"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding HasLogo, Converter={StaticResource InverseBoolToVis}}"/>
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="0,0,14,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Version, StringFormat='  v{0}'}" Foreground="{StaticResource HintBrush}" FontSize="12" Margin="4,0,0,0"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" Foreground="{StaticResource HintBrush}" FontSize="12" TextTrimming="CharacterEllipsis" MaxHeight="18" Margin="0,4,0,0"/>
                                                <WrapPanel Margin="0,7,0,0">
                                                    <ItemsControl ItemsSource="{Binding CategoryDescriptors}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="{x:Type vm:PluginMarketplaceCategoryDescriptor}">
                                                                <Border Style="{StaticResource BadgeStyle}" Margin="0,0,6,0">
                                                                    <TextBlock Text="{Binding DisplayName}" Foreground="#D6DEE9" FontSize="10"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <Border Style="{StaticResource BadgeStyle}" Margin="0,0,6,0">
                                                        <TextBlock Text="{Binding LocationBadge}" Foreground="#D6DEE9" FontSize="10"/>
                                                    </Border>
                                                    <Border Style="{StaticResource BadgeStyle}" Margin="0,0,6,0">
                                                        <TextBlock Text="{Binding SizeDisplay}" Foreground="#D6DEE9" FontSize="10"/>
                                                    </Border>
                                                </WrapPanel>
                                                <ProgressBar Value="{Binding Progress}" Maximum="1" Height="3" Margin="0,8,0,0" Visibility="{Binding IsWorking, Converter={StaticResource BoolToVis}}"/>
                                                <TextBlock Text="{Binding InstallErrorMessage}"
                                                           Foreground="{StaticResource DangerBrush}"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"
                                                           Margin="0,6,0,0"
                                                           Visibility="{Binding InstallErrorMessage, Converter={StaticResource NonEmptyToVis}}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <ui:Button Appearance="Primary"
                                                           Content="{loc:Str Plugins.Install}"
                                                           Command="{Binding InstallCommand}"
                                                           IsEnabled="{Binding IsWorking, Converter={StaticResource InvertBool}}"
                                                           Visibility="{Binding InstallState, Converter={StaticResource InstallStateToVis}, ConverterParameter=NotInstalled}"/>
                                                <ui:Button Appearance="Primary"
                                                           Content="{loc:Str Plugins.Update}"
                                                           Command="{Binding UpdateCommand}"
                                                           IsEnabled="{Binding IsWorking, Converter={StaticResource InvertBool}}"
                                                           Visibility="{Binding InstallState, Converter={StaticResource InstallStateToVis}, ConverterParameter=UpdateAvailable}"/>
                                                <TextBlock Foreground="{StaticResource ActiveIndicatorBrush}"
                                                           FontSize="12"
                                                           Visibility="{Binding InstallState, Converter={StaticResource InstallStateToVis}, ConverterParameter=Installed}">
                                                    <Run Text="&#x2705; "/><Run Text="{Binding Source={x:Static loc:Loc.Instance}, Path=[Plugins.InstalledBadge], Mode=OneWay}"/>
                                                </TextBlock>
                                                <TextBlock Foreground="{StaticResource WarningBrush}"
                                                           FontSize="12"
                                                           Visibility="{Binding InstallState, Converter={StaticResource InstallStateToVis}, ConverterParameter=PendingRestart}">
                                                    <Run Text="&#x21BB; "/><Run Text="{Binding Source={x:Static loc:Loc.Instance}, Path=[Plugins.RestartRequiredBadge], Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="TypeWhisper.Windows.Views.Sections.PluginsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:TypeWhisper.Windows.ViewModels"
             xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <conv:NonEmptyToVisibilityConverter x:Key="NonEmptyToVis"/>
            <conv:InstallStateToVisibilityConverter x:Key="InstallStateToVis"/>
            <conv:InvertBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
            <conv:InvertBoolConverter x:Key="InvertBool"/>
            <conv:StringToBrushConverter x:Key="StringToBrush"/>

            <!-- Tab button style -->
            <Style x:Key="TabButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource HintBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,0,2"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Active tab style -->
            <Style x:Key="ActiveTabButtonStyle" TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel Margin="24">
        <!-- Header -->
        <TextBlock DockPanel.Dock="Top" Text="Erweiterungen" Style="{StaticResource SectionHeaderStyle}"/>
        <TextBlock DockPanel.Dock="Top"
                   Text="Plugins erweitern TypeWhisper um zusätzliche Transkriptions-Engines, LLM-Anbieter und Nachbearbeitung."
                   Style="{StaticResource HintStyle}" Margin="0,0,0,12"/>

        <!-- Tab bar -->
        <Border DockPanel.Dock="Top" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="TabInstalled" Content="&#x1F9E9;  Installiert"
                        Style="{StaticResource ActiveTabButtonStyle}"
                        Click="OnInstalledTabClick"/>
                <Button x:Name="TabMarketplace" Content="&#x1F6D2;  Marketplace"
                        Style="{StaticResource TabButtonStyle}"
                        Click="OnMarketplaceTabClick"/>
            </StackPanel>
        </Border>

        <!-- Tab content -->
        <Grid>
            <!-- ==================== INSTALLED TAB ==================== -->
            <ScrollViewer x:Name="InstalledPanel" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Empty state -->
                    <Border x:Name="EmptyState" Visibility="Collapsed"
                            Background="{StaticResource InputBackgroundBrush}"
                            CornerRadius="8" Padding="32" Margin="0,0,0,8"
                            HorizontalAlignment="Stretch">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#x1F9E9;" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Keine Plugins installiert"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="14" FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Installiere Plugins über den Marketplace-Tab."
                                       Foreground="{StaticResource HintBrush}"
                                       FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Installed plugins list -->
                    <ItemsControl ItemsSource="{Binding Plugins.Plugins}"
                                  HorizontalContentAlignment="Stretch">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:PluginItemViewModel}">
                                <ui:CardExpander IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                                                 HorizontalContentAlignment="Stretch"
                                                 Margin="0,0,0,8">
                                    <ui:CardExpander.Header>
                                        <Grid Margin="0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Plugin icon -->
                                            <Border Grid.Column="0" Width="40" Height="40"
                                                    CornerRadius="8" Margin="0,0,12,0"
                                                    VerticalAlignment="Top"
                                                    Background="{Binding IconGradientStart, Converter={StaticResource StringToBrush}}">
                                                <TextBlock Text="{Binding IconEmoji}" FontSize="18"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Name + version + author + badges -->
                                            <StackPanel Grid.Column="1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                               FontSize="14" FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Version, StringFormat='  v{0}'}"
                                                               Foreground="{StaticResource HintBrush}"
                                                               FontSize="12" VerticalAlignment="Center"
                                                               Margin="4,0,0,0"/>
                                                </StackPanel>

                                                <!-- Author -->
                                                <TextBlock Text="{Binding Author}"
                                                           Foreground="{StaticResource HintBrush}"
                                                           FontSize="11" Margin="0,1,0,0"
                                                           Visibility="{Binding Author, Converter={StaticResource NonEmptyToVis}}"/>

                                                <!-- Description -->
                                                <TextBlock Text="{Binding Description}"
                                                           Foreground="{StaticResource HintBrush}"
                                                           FontSize="12" TextWrapping="Wrap"
                                                           Margin="0,4,0,0"
                                                           Visibility="{Binding Description, Converter={StaticResource NonEmptyToVis}}"/>

                                                <!-- Capability badges -->
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <Border Style="{StaticResource BadgeStyle}"
                                                            Visibility="{Binding IsTranscriptionProvider, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="&#x1F3A4; Transkription" Foreground="#CCCCCC" FontSize="10"/>
                                                    </Border>
                                                    <Border Style="{StaticResource BadgeStyle}"
                                                            Visibility="{Binding IsLlmProvider, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="&#x1F916; LLM" Foreground="#CCCCCC" FontSize="10"/>
                                                    </Border>
                                                    <Border Style="{StaticResource BadgeStyle}"
                                                            Visibility="{Binding IsPostProcessor, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="&#x2699; Post-Processing" Foreground="#CCCCCC" FontSize="10"/>
                                                    </Border>
                                                    <Border Style="{StaticResource BadgeStyle}"
                                                            Visibility="{Binding IsActionProvider, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="&#x26A1; Aktion" Foreground="#CCCCCC" FontSize="10"/>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Right side: toggle + uninstall -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                        VerticalAlignment="Center" Margin="12,0,0,0">
                                                <!-- Uninstall button -->
                                                <ui:Button Appearance="Secondary"
                                                           ToolTip="Deinstallieren"
                                                           Command="{Binding UninstallCommand}"
                                                           Padding="6,4" Margin="0,0,8,0"
                                                           VerticalAlignment="Center">
                                                    <ui:SymbolIcon Symbol="Delete24"/>
                                                </ui:Button>

                                                <!-- Enable/Disable toggle -->
                                                <ui:ToggleSwitch IsChecked="{Binding IsEnabled}"
                                                                 VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </ui:CardExpander.Header>

                                    <!-- Plugin settings view (content of expander) -->
                                    <ContentControl Content="{Binding SettingsView}"
                                                    Margin="0,8,0,0"
                                                    Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVis}}"/>
                                </ui:CardExpander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- ==================== MARKETPLACE TAB ==================== -->
            <ScrollViewer x:Name="MarketplacePanel" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                <StackPanel>
                    <!-- Refresh bar -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Verfügbare Erweiterungen zum Herunterladen und Installieren."
                                   Style="{StaticResource HintStyle}" VerticalAlignment="Center"/>
                        <ui:Button Grid.Column="1" Appearance="Secondary"
                                   Content="Aktualisieren"
                                   Command="{Binding Plugins.RefreshRegistryCommand}"
                                   Icon="{ui:SymbolIcon ArrowSync24}"/>
                    </Grid>

                    <!-- Loading indicator -->
                    <Border Visibility="{Binding Plugins.IsLoadingRegistry, Converter={StaticResource BoolToVis}}"
                            Background="{StaticResource InputBackgroundBrush}"
                            CornerRadius="8" Padding="24" Margin="0,0,0,8">
                        <StackPanel HorizontalAlignment="Center">
                            <ui:ProgressRing IsIndeterminate="True" Width="32" Height="32" Margin="0,0,0,8"/>
                            <TextBlock Text="Lade Marketplace..."
                                       Foreground="{StaticResource HintBrush}" FontSize="13"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Marketplace list -->
                    <ItemsControl ItemsSource="{Binding Plugins.RegistryPlugins}"
                                  Visibility="{Binding Plugins.IsLoadingRegistry, Converter={StaticResource InverseBoolToVis}}"
                                  HorizontalContentAlignment="Stretch">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:RegistryPluginItemViewModel}">
                                <Border Margin="0,0,0,8" Padding="16,12"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1" CornerRadius="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Plugin icon -->
                                        <Border Grid.Column="0" Width="40" Height="40"
                                                CornerRadius="8" Margin="0,0,12,0"
                                                VerticalAlignment="Top"
                                                Background="{Binding IconGradientStart, Converter={StaticResource StringToBrush}}">
                                            <TextBlock Text="{Binding IconEmoji}" FontSize="18"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Info -->
                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                           FontSize="14" FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Version, StringFormat='  v{0}'}"
                                                           Foreground="{StaticResource HintBrush}"
                                                           FontSize="12" VerticalAlignment="Center"
                                                           Margin="4,0,0,0"/>
                                                <TextBlock Text="{Binding SizeDisplay, StringFormat='  ({0})'}"
                                                           Foreground="{StaticResource HintBrush}"
                                                           FontSize="11" VerticalAlignment="Center"
                                                           Margin="4,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Author}"
                                                       Foreground="{StaticResource HintBrush}"
                                                       FontSize="11" Margin="0,1,0,0"/>
                                            <TextBlock Text="{Binding Description}"
                                                       Foreground="{StaticResource HintBrush}"
                                                       FontSize="12" TextWrapping="Wrap"
                                                       Margin="0,4,0,0"/>

                                            <!-- Progress bar -->
                                            <ProgressBar Value="{Binding Progress}" Maximum="1" Height="3"
                                                         Margin="0,8,0,0"
                                                         Visibility="{Binding IsWorking, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>

                                        <!-- Action buttons -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="12,0,0,0">
                                            <!-- Install -->
                                            <ui:Button Appearance="Primary"
                                                       Content="Installieren"
                                                       Command="{Binding InstallCommand}"
                                                       IsEnabled="{Binding IsWorking, Converter={StaticResource InvertBool}}"
                                                       Visibility="{Binding InstallState, Converter={StaticResource InstallStateToVis}, ConverterParameter=NotInstalled}"/>

                                            <!-- Update -->
                                            <ui:Button Appearance="Secondary"
                                                       Content="Aktualisieren"
                                                       Command="{Binding UpdateCommand}"
                                                       Visibility="{Binding InstallState, Converter={StaticResource InstallStateToVis}, ConverterParameter=UpdateAvailable}"/>

                                            <!-- Installed checkmark -->
                                            <TextBlock Text="&#x2705; Installiert"
                                                       Foreground="{StaticResource ActiveIndicatorBrush}"
                                                       FontSize="12"
                                                       Visibility="{Binding InstallState, Converter={StaticResource InstallStateToVis}, ConverterParameter=Installed}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</UserControl>

<UserControl x:Class="TypeWhisper.Windows.Views.Sections.ProfilesSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters"
             xmlns:controls="clr-namespace:TypeWhisper.Windows.Controls"
             xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <conv:ProfileSubtitleConverter x:Key="ProfileSubtitleConverter"/>
            <conv:NonEmptyToVisibilityConverter x:Key="NonEmptyToVisibility"/>

            <Style x:Key="ChipRemoveButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="{StaticResource HintBrush}"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="4,0,0,0"/>
                <Setter Property="Width" Value="14"/>
                <Setter Property="Height" Value="14"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                <Setter Property="FontSize" Value="9"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="DangerLinkButtonStyle" TargetType="Button" BasedOn="{StaticResource LinkButtonStyle}">
                <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
            </Style>

            <Style x:Key="ProfilePanelTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource SettingsGroupTitleStyle}">
                <Setter Property="FontSize" Value="14.5"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
            </Style>

            <Style x:Key="ProfileFieldLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource SettingsRowLabelStyle}">
                <Setter Property="FontSize" Value="11.5"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource HintBrush}"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
            </Style>

            <Style x:Key="ProfileRowLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource SettingsRowLabelStyle}">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#D6DEE9"/>
            </Style>

            <Style x:Key="ProfileAlignedComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource SettingsAlignedComboBoxStyle}">
                <Setter Property="Width" Value="320"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="MinHeight" Value="40"/>
                <Setter Property="MaxHeight" Value="40"/>
                <Setter Property="Padding" Value="6,0,6,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="ProfileListBoxItemStyle" TargetType="ListBoxItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource LabelBrush}"/>
                <Setter Property="Padding" Value="14,10"/>
                <Setter Property="Margin" Value="0,0,12,6"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="RowHost"
                                    Background="Transparent"
                                    CornerRadius="10"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border x:Name="SelectionBar"
                                            Grid.Column="0"
                                            Background="{StaticResource AccentBrush}"
                                            CornerRadius="2"
                                            Margin="0,3,0,3"
                                            Opacity="0"/>

                                    <ContentPresenter Grid.Column="2"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="RowHost" Property="Background" Value="#162231"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="RowHost" Property="Background" Value="#203347"/>
                                    <Setter TargetName="SelectionBar" Property="Opacity" Value="1"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ProfileListBoxStyle" TargetType="ListBox" BasedOn="{StaticResource MasterListBoxStyle}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
                <Setter Property="ItemContainerStyle" Value="{StaticResource ProfileListBoxItemStyle}"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="18"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock Text="{loc:Str Profiles.Title}" Style="{StaticResource ProfilePanelTitleStyle}"/>
                <TextBlock Text="{Binding Profiles.ProfileSummary}" Style="{StaticResource PageSubtitleStyle}" Margin="0"/>
            </StackPanel>

            <ListBox Grid.Row="1"
                     Margin="0,6,0,0"
                     ItemsSource="{Binding Profiles.Profiles}"
                     SelectedItem="{Binding Profiles.SelectedProfile}"
                     Style="{StaticResource ProfileListBoxStyle}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Converter={StaticResource ProfileSubtitleConverter}}" FontSize="11" Foreground="{StaticResource HintBrush}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1"
                                             IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                             VerticalAlignment="Center"
                                             Checked="ProfileToggle_Changed"
                                             Unchecked="ProfileToggle_Changed"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button Grid.Row="2"
                    Content="{loc:Str Profiles.NewProfile}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding Profiles.AddProfileCommand}"
                    Padding="12,8"
                    HorizontalAlignment="Stretch"
                    Margin="0,12,0,0"/>
        </Grid>

        <Border Grid.Column="2"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                MaxWidth="380">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource SettingsSummaryBarStyle}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Profiles.SelectedProfile}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <TextBlock Text="{loc:Str Profiles.SelectProfile}" Style="{StaticResource SettingsGroupTitleStyle}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <TextBlock Text="{loc:Str Profiles.SelectProfileHint}" Style="{StaticResource PageSubtitleStyle}" TextAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Profiles.SelectedProfile}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel MaxWidth="920" Margin="0,0,24,0">
                    <Border Style="{StaticResource SettingsSectionFormStyle}">
                        <StackPanel Margin="18,16">
                            <TextBlock Text="{loc:Str Profiles.Name}" Style="{StaticResource ProfileFieldLabelStyle}"/>
                            <TextBox Text="{Binding Profiles.EditName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsCompactTextBoxStyle}" Margin="0,0,0,14"/>

                            <TextBlock Text="{loc:Str Profiles.Apps}" Style="{StaticResource ProfileFieldLabelStyle}"/>
                            <ItemsControl ItemsSource="{Binding Profiles.ProcessNameChips}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource BadgeStyle}" Margin="0,0,6,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding}" Foreground="#D6DEE9" FontSize="10.5"/>
                                                <Button Content="&#xE711;"
                                                        Style="{StaticResource ChipRemoveButtonStyle}"
                                                        Command="{Binding DataContext.Profiles.RemoveProcessNameChipCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBox x:Name="ProcessNameInputBox"
                                     Text="{Binding Profiles.ProcessNameInput, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource SettingsCompactTextBoxStyle}"
                                     KeyDown="ProcessNameInputBox_KeyDown"/>
                            <TextBlock Text="{loc:Str Profiles.ProcessNameHint}" Style="{StaticResource HintStyle}" Margin="0,8,0,14"/>

                            <TextBlock Text="{loc:Str Profiles.UrlPatterns}" Style="{StaticResource ProfileFieldLabelStyle}"/>
                            <ItemsControl ItemsSource="{Binding Profiles.UrlPatternChips}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource BadgeStyle}" Margin="0,0,6,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding}" Foreground="#D6DEE9" FontSize="10.5"/>
                                                <Button Content="&#xE711;"
                                                        Style="{StaticResource ChipRemoveButtonStyle}"
                                                        Command="{Binding DataContext.Profiles.RemoveUrlPatternChipCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBox x:Name="UrlPatternInputBox"
                                     Text="{Binding Profiles.UrlPatternInput, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource SettingsCompactTextBoxStyle}"
                                     KeyDown="UrlPatternInputBox_KeyDown"/>
                            <TextBlock Text="{loc:Str Profiles.UrlPatternHint}" Style="{StaticResource HintStyle}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{loc:Str Profiles.Overrides}" Style="{StaticResource ProfilePanelTitleStyle}" Margin="0,4,0,8"/>
                    <Border Style="{StaticResource SettingsSectionFormStyle}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Str Profiles.LanguageLabel}" Style="{StaticResource ProfileRowLabelStyle}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding Profiles.LanguageOptions}"
                                              SelectedValue="{Binding Profiles.EditLanguage}"
                                              SelectedValuePath="Value"
                                              DisplayMemberPath="DisplayName"
                                              Style="{StaticResource ProfileAlignedComboBoxStyle}"/>
                                </Grid>
                            </Border>
                            <Border Height="1" Background="#16FFFFFF"/>
                            <Border Style="{StaticResource SettingsRowBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,14,0">
                                        <TextBlock Text="{loc:Str Profiles.TaskLabel}" Style="{StaticResource ProfileRowLabelStyle}" Margin="0,0,0,6"/>
                                        <TextBlock Text="{loc:Str Profiles.TaskHint}" Style="{StaticResource HintStyle}" Margin="0"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding Profiles.TaskOptions}"
                                              SelectedValue="{Binding Profiles.EditTask}"
                                              SelectedValuePath="Value"
                                              DisplayMemberPath="DisplayName"
                                              Style="{StaticResource ProfileAlignedComboBoxStyle}"/>
                                </Grid>
                            </Border>
                            <Border Height="1" Background="#16FFFFFF"/>
                            <Border Style="{StaticResource SettingsRowBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,14,0">
                                        <TextBlock Text="{loc:Str Profiles.TranslationLabel}" Style="{StaticResource ProfileRowLabelStyle}" Margin="0,0,0,6"/>
                                        <TextBlock Text="{loc:Str Profiles.TranslationOverrideHint}" Style="{StaticResource HintStyle}" Margin="0"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding Profiles.TranslationTargetOptions}"
                                              SelectedValue="{Binding Profiles.EditTranslationTarget}"
                                              SelectedValuePath="Code"
                                              TextSearch.TextPath="DisplayName"
                                              DisplayMemberPath="DisplayName"
                                              Style="{StaticResource ProfileAlignedComboBoxStyle}"/>
                                </Grid>
                            </Border>
                            <Border Height="1" Background="#16FFFFFF"/>
                            <Border Style="{StaticResource SettingsRowBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,14,0">
                                        <TextBlock Text="{loc:Str Profiles.WhisperModeOverride}" Style="{StaticResource ProfileRowLabelStyle}" Margin="0,0,0,6"/>
                                        <TextBlock Text="{loc:Str Profiles.WhisperModeOverrideHint}" Style="{StaticResource HintStyle}" Margin="0"/>
                                    </StackPanel>
                                    <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding Profiles.EditWhisperModeOverride}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Height="1" Background="#16FFFFFF"/>
                            <Border Style="{StaticResource SettingsRowBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,14,0">
                                        <TextBlock Text="{loc:Str Profiles.TranscriptionModel}" Style="{StaticResource ProfileRowLabelStyle}" Margin="0,0,0,6"/>
                                        <TextBlock Text="{loc:Str Profiles.TranscriptionModelHint}" Style="{StaticResource HintStyle}" Margin="0"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding Profiles.AvailableModelOptions}"
                                              SelectedValue="{Binding Profiles.EditTranscriptionModelOverride}"
                                              SelectedValuePath="Id"
                                              DisplayMemberPath="DisplayName"
                                              Style="{StaticResource ProfileAlignedComboBoxStyle}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{loc:Str Profiles.ActivationSection}" Style="{StaticResource ProfilePanelTitleStyle}" Margin="0,4,0,8"/>
                    <Border Style="{StaticResource SettingsSectionFormStyle}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Str Profiles.EnabledLabel}" Style="{StaticResource ProfileRowLabelStyle}" VerticalAlignment="Center"/>
                                    <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding Profiles.EditIsEnabled}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Height="1" Background="#16FFFFFF"/>
                            <Border Style="{StaticResource SettingsRowBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,14,0">
                                        <TextBlock Text="{loc:Str Profiles.HotkeyLabel}" Style="{StaticResource ProfileRowLabelStyle}" Margin="0,0,0,6"/>
                                        <TextBlock Text="{loc:Str Profiles.HotkeyHint}" Style="{StaticResource HintStyle}" Margin="0"/>
                                    </StackPanel>
                                    <controls:HotkeyRecorderControl Grid.Column="1" Hotkey="{Binding Profiles.EditHotkey, Mode=TwoWay}" HorizontalAlignment="Right" Width="250"/>
                                </Grid>
                            </Border>
                            <Border Height="1" Background="#16FFFFFF"/>
                            <Border Style="{StaticResource SettingsRowBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,14,0">
                                        <TextBlock Text="{loc:Str Profiles.Priority}" Style="{StaticResource ProfileRowLabelStyle}" Margin="0,0,0,6"/>
                                        <TextBlock Text="{loc:Str Profiles.PriorityHint}" Style="{StaticResource HintStyle}" Margin="0"/>
                                    </StackPanel>
                                    <TextBox Grid.Column="1" Text="{Binding Profiles.EditPriority, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsNumericTextBoxStyle}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{loc:Str Profiles.ActionsSection}" Style="{StaticResource ProfilePanelTitleStyle}" Margin="0,4,0,8"/>
                    <Border Style="{StaticResource SettingsSectionFormStyle}">
                        <Grid Margin="18,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,14,0">
                                <TextBlock Text="{loc:Str Profiles.ActionsSection}" Style="{StaticResource ProfileRowLabelStyle}" Margin="0,0,0,6"/>
                                <TextBlock Text="{loc:Str Profiles.ActionsHint}" Style="{StaticResource HintStyle}" Margin="0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="{loc:Str Profiles.Duplicate}"
                                    Style="{StaticResource LinkButtonStyle}"
                                    Command="{Binding Profiles.DuplicateProfileCommand}"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"/>
                            <Button Grid.Column="2"
                                    Content="{loc:Str Profiles.Delete}"
                                    Style="{StaticResource DangerLinkButtonStyle}"
                                    Command="{Binding Profiles.DeleteProfileCommand}"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="1" Style="{StaticResource SettingsStickyFooterStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{loc:Str Profiles.SaveHint}" Style="{StaticResource HintStyle}" Margin="0" VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Content="{loc:Str Profiles.OpenLiveContext}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding Profiles.OpenLiveContextWindowCommand}"
                            Padding="12,8"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"/>
                    <Button Grid.Column="2"
                            Content="{loc:Str Profiles.Save}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding Profiles.SaveProfileCommand}"
                            Padding="16,8"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

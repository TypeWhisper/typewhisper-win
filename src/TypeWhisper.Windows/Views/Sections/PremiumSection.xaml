<UserControl x:Class="TypeWhisper.Windows.Views.Sections.PremiumSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization"
             xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
            <conv:NonEmptyToVisibilityConverter x:Key="NonEmptyToVisibility"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,22,28,28" MaxWidth="900">
            <StackPanel Style="{StaticResource SettingsSectionStyle}">
                <TextBlock Text="{loc:Str Premium.Title}"
                           Style="{StaticResource SectionHeaderStyle}"/>
                <TextBlock Text="{loc:Str Premium.Subtitle}"
                           Style="{StaticResource PageSubtitleStyle}"
                           Margin="0,0,0,16"/>

                <Border Style="{StaticResource SettingsActionBarStyle}"
                        Visibility="{Binding CloudFolderSync.ShowLockedState, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="40"
                                Height="40"
                                CornerRadius="8"
                                Background="#2D3A27"
                                Margin="0,0,14,0">
                            <TextBlock Text="&#xE72E;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{loc:Str Premium.LockedTitle}"
                                       Style="{StaticResource SettingsGroupTitleStyle}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{loc:Str Premium.LockedDescription}"
                                       Style="{StaticResource HintStyle}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <ui:Button Grid.Column="2"
                                   Content="{loc:Str Premium.OpenLicense}"
                                   Appearance="Primary"
                                   Margin="16,0,0,0"
                                   Click="OnOpenLicense"/>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Style="{StaticResource SettingsSectionStyle}"
                        Visibility="{Binding CloudFolderSync.ShowSyncControls, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{loc:Str Premium.CloudFolderSyncTitle}"
                           Style="{StaticResource SettingsGroupTitleStyle}"/>

                <Border Style="{StaticResource SettingsGroupPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str Premium.Provider}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding CloudFolderSync.ProviderDisplayName}"
                                           Style="{StaticResource SettingsValueTextStyle}"/>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Background="#18FFFFFF"/>

                        <Border Grid.Row="2" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str Premium.Folder}"
                                           Style="{StaticResource SettingsRowLabelStyle}"
                                           Margin="0,0,16,0"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding CloudFolderSync.SelectedFolderDisplayName}"
                                           Style="{StaticResource SettingsValueTextStyle}"
                                           TextTrimming="CharacterEllipsis"/>
                                <ui:Button Grid.Column="2"
                                           Content="{loc:Str Premium.ChooseFolder}"
                                           Appearance="Secondary"
                                           Margin="16,0,0,0"
                                           Click="OnChooseFolder"/>
                            </Grid>
                        </Border>
                        <Border Grid.Row="3" Background="#18FFFFFF"/>

                        <Border Grid.Row="4" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str Premium.LastSync}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding CloudFolderSync.LastSyncDisplay}"
                                           Style="{StaticResource SettingsValueTextStyle}"/>
                            </Grid>
                        </Border>
                        <Border Grid.Row="5" Background="#18FFFFFF"/>

                        <Border Grid.Row="6" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str Premium.Pending}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding CloudFolderSync.PendingChanges}"
                                           Style="{StaticResource SettingsValueTextStyle}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsActionBarStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{loc:Str Premium.CommercialActive}"
                                       Style="{StaticResource SettingsGroupTitleStyle}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding CloudFolderSync.StatusMessage}"
                                       Style="{StaticResource HintStyle}"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding CloudFolderSync.StatusMessage, Converter={StaticResource NonEmptyToVisibility}}"/>
                            <TextBlock Text="{Binding CloudFolderSync.ErrorMessage}"
                                       Foreground="{StaticResource DangerBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding CloudFolderSync.ErrorMessage, Converter={StaticResource NonEmptyToVisibility}}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <ui:Button Content="{loc:Str Premium.SyncNow}"
                                       Command="{Binding CloudFolderSync.SyncNowCommand}"
                                       Appearance="Primary"
                                       Margin="0,0,8,0"/>
                            <ui:Button Content="{loc:Str Premium.Clear}"
                                       Command="{Binding CloudFolderSync.ClearFolderCommand}"
                                       Appearance="Secondary"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>

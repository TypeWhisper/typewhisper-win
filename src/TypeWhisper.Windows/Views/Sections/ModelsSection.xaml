<UserControl x:Class="TypeWhisper.Windows.Views.Sections.ModelsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:TypeWhisper.Windows.ViewModels"
             xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="600" Margin="24">
            <TextBlock Text="{loc:Str Models.Title}" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="{loc:Str Models.Subtitle}"
                       Style="{StaticResource HintStyle}" Margin="0,0,0,16"/>

            <!-- Status message -->
            <TextBlock Text="{Binding ModelManager.BusyMessage}"
                       Foreground="{StaticResource AccentBrush}" FontSize="12"
                       Margin="0,0,0,8"
                       Visibility="{Binding ModelManager.IsBusy, Converter={StaticResource BoolToVis}}"/>

            <Grid Margin="0,0,0,16"
                  Visibility="{Binding ModelManager.IsAccelerationSectionVisible, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{loc:Str Models.AccelerationLabel}"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           FontSize="13" FontWeight="SemiBold"/>
                <ComboBox Grid.Row="0" Grid.Column="1"
                          ItemsSource="{Binding ModelManager.AccelerationOptions}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding ModelManager.SelectedAccelerationOptionValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          MinWidth="160"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="{loc:Str Models.AccelerationHint}"
                           Style="{StaticResource HintStyle}" Margin="0,4,0,0"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="{Binding ModelManager.AccelerationStatusText}"
                           Foreground="{StaticResource HintBrush}" FontSize="12"
                           Margin="0,4,0,0"/>
                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0"
                            Visibility="{Binding ModelManager.IsAccelerationRestartRequired, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ModelManager.AccelerationRestartMessage}"
                               Style="{StaticResource HintStyle}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="360"
                               Margin="0,0,10,0"/>
                    <ui:Button Content="{loc:Str Models.AccelerationRestartNow}"
                               Command="{Binding ModelManager.RestartForAccelerationCommand}"
                               Appearance="Primary"/>
                </StackPanel>
            </Grid>

            <ItemsControl ItemsSource="{Binding ModelManager.Providers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ProviderViewModel}">
                        <ui:CardExpander IsExpanded="True" Margin="0,0,0,12">
                            <ui:CardExpander.Header>
                                <StackPanel Margin="0,4">
                                    <!-- Provider Header -->
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <!-- Capabilities hint -->
                                    <TextBlock Foreground="{StaticResource HintBrush}" FontSize="11" Margin="0,2,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{loc:Str Models.Transcription}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasLlmTranslation}" Value="True">
                                                        <Setter Property="Text" Value="{loc:Str Models.TranscriptionLlm}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <!-- API Key hint (only for cloud providers that need configuration) -->
                                    <TextBlock Foreground="{StaticResource HintBrush}" FontSize="11"
                                               FontStyle="Italic" Margin="0,2,0,0"
                                               Text="{loc:Str Models.ApiKeyHint}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SupportsDownload}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsConfigured}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </ui:CardExpander.Header>

                            <!-- Models List -->
                            <ItemsControl ItemsSource="{Binding Models}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ModelItemViewModel}">
                                        <Border Padding="8,6" Margin="0,2"
                                                CornerRadius="4" Cursor="Hand"
                                                MouseLeftButtonUp="Model_Click">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#333333"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="#1A4CAF50"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Foreground="{StaticResource TextBrush}" FontSize="13"/>
                                                        <TextBlock Text="{loc:Str Models.Recommended}" Foreground="{StaticResource ActiveIndicatorBrush}"
                                                                   FontSize="13"
                                                                   Visibility="{Binding IsRecommended, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0"
                                                               Visibility="{Binding SupportsDownload, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="{Binding SizeDescription}" Foreground="{StaticResource HintBrush}" FontSize="11"/>
                                                        <TextBlock Foreground="{StaticResource HintBrush}" FontSize="11"
                                                                   Text="{Binding LanguageCount, StringFormat=' · {0} languages'}"/>
                                                        <TextBlock Foreground="{StaticResource HintBrush}" FontSize="11"
                                                                   Visibility="{Binding SupportsTranslation, Converter={StaticResource BoolToVis}}"
                                                                   Text="{loc:Str Models.TranslationBadge}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource HintBrush}" FontSize="11"/>
                                                </StackPanel>
                                                <!-- Active indicator -->
                                                <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                           FontSize="11" Margin="8,0,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value=""/>
                                                            <Setter Property="Foreground" Value="{StaticResource HintBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Text" Value="{loc:Str Models.Active}"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource ActiveIndicatorBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ui:CardExpander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>

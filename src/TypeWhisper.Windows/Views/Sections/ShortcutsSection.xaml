<UserControl x:Class="TypeWhisper.Windows.Views.Sections.ShortcutsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:TypeWhisper.Windows.Controls">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28" MaxWidth="860">
            <StackPanel Margin="0,0,0,18">
                <TextBlock Text="Shortcuts"
                           Style="{StaticResource SettingsGroupTitleStyle}"
                           Margin="0,0,0,6"/>
                <TextBlock Text="Keep capture keyboard-first. Start with one main hotkey, then add dedicated variants only when you really need them."
                           Style="{StaticResource PageSubtitleStyle}"
                           Margin="0"/>
            </StackPanel>

            <TextBlock Text="Main capture"
                       Style="{StaticResource NavGroupLabelStyle}"
                       Margin="0,0,0,8"/>

            <Border Style="{StaticResource SettingsGroupPanelStyle}">
                <StackPanel>
                    <Border Style="{StaticResource SettingsRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Main dictation hotkey"
                                           Style="{StaticResource SettingsRowLabelStyle}"/>
                                <TextBlock Text="Short press toggles recording. Hold the same shortcut for push-to-talk."
                                           Style="{StaticResource PageSubtitleStyle}"
                                           FontSize="12"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <controls:HotkeyRecorderControl Grid.Column="1"
                                                            Hotkey="{Binding Settings.PushToTalkHotkey}"
                                                            AllowModifierOnly="True"
                                                            Width="240"
                                                            VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <TextBlock Text="More shortcuts"
                       Style="{StaticResource NavGroupLabelStyle}"
                       Margin="0,0,0,8"/>

            <Border Style="{StaticResource SettingsGroupPanelStyle}">
                <StackPanel>
                    <Border Style="{StaticResource SettingsRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Toggle-only"
                                           Style="{StaticResource SettingsRowLabelStyle}"/>
                                <TextBlock Text="Start and stop dictation with a dedicated shortcut."
                                           Style="{StaticResource PageSubtitleStyle}"
                                           FontSize="12"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <controls:HotkeyRecorderControl Grid.Column="1"
                                                            Hotkey="{Binding Settings.ToggleOnlyHotkey}"
                                                            AllowModifierOnly="True"
                                                            Width="240"
                                                            VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Height="1"
                            Background="#16FFFFFF"
                            Margin="18,0"/>

                    <Border Style="{StaticResource SettingsRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Hold-only"
                                           Style="{StaticResource SettingsRowLabelStyle}"/>
                                <TextBlock Text="Pure push-to-talk without toggle mode."
                                           Style="{StaticResource PageSubtitleStyle}"
                                           FontSize="12"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <controls:HotkeyRecorderControl Grid.Column="1"
                                                            Hotkey="{Binding Settings.HoldOnlyHotkey}"
                                                            AllowModifierOnly="True"
                                                            Width="240"
                                                            VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Height="1"
                            Background="#16FFFFFF"
                            Margin="18,0"/>

                    <Border Style="{StaticResource SettingsRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Prompt palette"
                                           Style="{StaticResource SettingsRowLabelStyle}"/>
                                <TextBlock Text="Open the AI prompt palette without starting dictation."
                                           Style="{StaticResource PageSubtitleStyle}"
                                           FontSize="12"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <controls:HotkeyRecorderControl Grid.Column="1"
                                                            Hotkey="{Binding Settings.PromptPaletteHotkey}"
                                                            AllowModifierOnly="True"
                                                            Width="240"
                                                            VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

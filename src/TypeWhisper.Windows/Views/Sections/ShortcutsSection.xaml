<UserControl x:Class="TypeWhisper.Windows.Views.Sections.ShortcutsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:TypeWhisper.Windows.Controls"
             xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters"
             xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:NonEmptyToVisibilityConverter x:Key="NonEmptyToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28" MaxWidth="860">
            <StackPanel Margin="0,0,0,18">
                <TextBlock Text="{loc:Str Nav.Shortcuts}"
                           Style="{StaticResource SettingsGroupTitleStyle}"
                           Margin="0,0,0,6"/>
                <TextBlock Text="{loc:Str Shortcuts.Subtitle}"
                           Style="{StaticResource PageSubtitleStyle}"
                           Margin="0"/>
                <TextBlock Text="{loc:Str Hotkey.ModifierOnlyHint}"
                           Style="{StaticResource HintStyle}"
                           Margin="0,8,0,0"/>
                <TextBlock Text="{Binding Settings.ShortcutsError}"
                           Foreground="{StaticResource DangerBrush}"
                           FontSize="12"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           Visibility="{Binding Settings.ShortcutsError, Converter={StaticResource NonEmptyToVis}}"/>
            </StackPanel>

            <TextBlock Text="{loc:Str Shortcuts.MainSection}"
                       Style="{StaticResource NavGroupLabelStyle}"
                       Margin="0,0,0,8"/>

            <Border Style="{StaticResource SettingsGroupPanelStyle}">
                <StackPanel>
                    <Border Style="{StaticResource SettingsRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="{loc:Str Shortcuts.MainHotkey}"
                                           Style="{StaticResource SettingsRowLabelStyle}"/>
                                <TextBlock Text="{loc:Str Shortcuts.MainHotkeyHint}"
                                           Style="{StaticResource PageSubtitleStyle}"
                                           FontSize="12"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Width="320"
                                        VerticalAlignment="Center">
                                <ItemsControl ItemsSource="{Binding Settings.MainDictationHotkeys}"
                                              HorizontalAlignment="Right"
                                              Margin="0,0,0,6">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel HorizontalAlignment="Right"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource HotkeyChipStyle}" Margin="0,0,6,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding}"
                                                               Foreground="{StaticResource TextBrush}"
                                                               FontSize="12"
                                                               VerticalAlignment="Center"/>
                                                    <Button Style="{StaticResource HotkeyChipCloseButtonStyle}"
                                                            Command="{Binding DataContext.Settings.RemoveMainDictationHotkeyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="{loc:Str Shortcuts.RemoveHotkey}"
                                                            AutomationProperties.Name="{loc:Str Shortcuts.RemoveHotkey}">
                                                        <TextBlock Text="&#xE711;"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="8"
                                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <controls:HotkeyRecorderControl Hotkey="{Binding Settings.NewMainDictationHotkey, Mode=TwoWay}"
                                                                RecordedCommand="{Binding Settings.AddMainDictationHotkeyCommand}"
                                                                UseAddGlyph="True"
                                                                ToolTip="{loc:Str Shortcuts.AddHotkey}"
                                                                AllowModifierOnly="True"
                                                                HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <TextBlock Text="{loc:Str Shortcuts.MoreSection}"
                       Style="{StaticResource NavGroupLabelStyle}"
                       Margin="0,0,0,8"/>

            <Border Style="{StaticResource SettingsGroupPanelStyle}">
                <StackPanel>
                    <Border Style="{StaticResource SettingsRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="{loc:Str Shortcuts.ToggleOnly}"
                                           Style="{StaticResource SettingsRowLabelStyle}"/>
                                <TextBlock Text="{loc:Str Shortcuts.ToggleOnlyHint}"
                                           Style="{StaticResource PageSubtitleStyle}"
                                           FontSize="12"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Width="320" VerticalAlignment="Center">
                                <ItemsControl ItemsSource="{Binding Settings.ToggleOnlyHotkeys}"
                                              HorizontalAlignment="Right"
                                              Margin="0,0,0,6">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel HorizontalAlignment="Right"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource HotkeyChipStyle}" Margin="0,0,6,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding}" Foreground="{StaticResource TextBrush}" FontSize="12" VerticalAlignment="Center"/>
                                                    <Button Style="{StaticResource HotkeyChipCloseButtonStyle}"
                                                            Command="{Binding DataContext.Settings.RemoveToggleOnlyHotkeyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="{loc:Str Shortcuts.RemoveHotkey}"
                                                            AutomationProperties.Name="{loc:Str Shortcuts.RemoveHotkey}">
                                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="8" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <controls:HotkeyRecorderControl Hotkey="{Binding Settings.NewToggleOnlyHotkey, Mode=TwoWay}"
                                                                RecordedCommand="{Binding Settings.AddToggleOnlyHotkeyCommand}"
                                                                UseAddGlyph="True"
                                                                ToolTip="{loc:Str Shortcuts.AddHotkey}"
                                                                AllowModifierOnly="True"
                                                                HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Height="1" Background="#16FFFFFF" Margin="18,0"/>

                    <Border Style="{StaticResource SettingsRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="{loc:Str Shortcuts.HoldOnly}"
                                           Style="{StaticResource SettingsRowLabelStyle}"/>
                                <TextBlock Text="{loc:Str Shortcuts.HoldOnlyHint}"
                                           Style="{StaticResource PageSubtitleStyle}"
                                           FontSize="12"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Width="320" VerticalAlignment="Center">
                                <ItemsControl ItemsSource="{Binding Settings.HoldOnlyHotkeys}"
                                              HorizontalAlignment="Right"
                                              Margin="0,0,0,6">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel HorizontalAlignment="Right"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource HotkeyChipStyle}" Margin="0,0,6,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding}" Foreground="{StaticResource TextBrush}" FontSize="12" VerticalAlignment="Center"/>
                                                    <Button Style="{StaticResource HotkeyChipCloseButtonStyle}"
                                                            Command="{Binding DataContext.Settings.RemoveHoldOnlyHotkeyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="{loc:Str Shortcuts.RemoveHotkey}"
                                                            AutomationProperties.Name="{loc:Str Shortcuts.RemoveHotkey}">
                                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="8" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <controls:HotkeyRecorderControl Hotkey="{Binding Settings.NewHoldOnlyHotkey, Mode=TwoWay}"
                                                                RecordedCommand="{Binding Settings.AddHoldOnlyHotkeyCommand}"
                                                                UseAddGlyph="True"
                                                                ToolTip="{loc:Str Shortcuts.AddHotkey}"
                                                                AllowModifierOnly="True"
                                                                HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <TextBlock Text="{loc:Str Shortcuts.RecentSection}"
                       Style="{StaticResource NavGroupLabelStyle}"
                       Margin="0,0,0,8"/>

            <Border Style="{StaticResource SettingsGroupPanelStyle}">
                <StackPanel>
                    <Border Style="{StaticResource SettingsRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="{loc:Str Shortcuts.RecentTranscriptions}"
                                           Style="{StaticResource SettingsRowLabelStyle}"/>
                                <TextBlock Text="{loc:Str Shortcuts.RecentTranscriptionsHint}"
                                           Style="{StaticResource PageSubtitleStyle}"
                                           FontSize="12"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Width="320" VerticalAlignment="Center">
                                <ItemsControl ItemsSource="{Binding Settings.RecentTranscriptionsHotkeys}"
                                              HorizontalAlignment="Right"
                                              Margin="0,0,0,6">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel HorizontalAlignment="Right"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource HotkeyChipStyle}" Margin="0,0,6,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding}" Foreground="{StaticResource TextBrush}" FontSize="12" VerticalAlignment="Center"/>
                                                    <Button Style="{StaticResource HotkeyChipCloseButtonStyle}"
                                                            Command="{Binding DataContext.Settings.RemoveRecentTranscriptionsHotkeyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="{loc:Str Shortcuts.RemoveHotkey}"
                                                            AutomationProperties.Name="{loc:Str Shortcuts.RemoveHotkey}">
                                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="8" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <controls:HotkeyRecorderControl Hotkey="{Binding Settings.NewRecentTranscriptionsHotkey, Mode=TwoWay}"
                                                                RecordedCommand="{Binding Settings.AddRecentTranscriptionsHotkeyCommand}"
                                                                UseAddGlyph="True"
                                                                ToolTip="{loc:Str Shortcuts.AddHotkey}"
                                                                AllowModifierOnly="True"
                                                                HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Height="1" Background="#16FFFFFF" Margin="18,0"/>

                    <Border Style="{StaticResource SettingsRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="{loc:Str Shortcuts.CopyLastTranscription}"
                                           Style="{StaticResource SettingsRowLabelStyle}"/>
                                <TextBlock Text="{loc:Str Shortcuts.CopyLastTranscriptionHint}"
                                           Style="{StaticResource PageSubtitleStyle}"
                                           FontSize="12"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Width="320" VerticalAlignment="Center">
                                <ItemsControl ItemsSource="{Binding Settings.CopyLastTranscriptionHotkeys}"
                                              HorizontalAlignment="Right"
                                              Margin="0,0,0,6">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel HorizontalAlignment="Right"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource HotkeyChipStyle}" Margin="0,0,6,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding}" Foreground="{StaticResource TextBrush}" FontSize="12" VerticalAlignment="Center"/>
                                                    <Button Style="{StaticResource HotkeyChipCloseButtonStyle}"
                                                            Command="{Binding DataContext.Settings.RemoveCopyLastTranscriptionHotkeyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="{loc:Str Shortcuts.RemoveHotkey}"
                                                            AutomationProperties.Name="{loc:Str Shortcuts.RemoveHotkey}">
                                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="8" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <controls:HotkeyRecorderControl Hotkey="{Binding Settings.NewCopyLastTranscriptionHotkey, Mode=TwoWay}"
                                                                RecordedCommand="{Binding Settings.AddCopyLastTranscriptionHotkeyCommand}"
                                                                UseAddGlyph="True"
                                                                ToolTip="{loc:Str Shortcuts.AddHotkey}"
                                                                AllowModifierOnly="True"
                                                                HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Height="1" Background="#16FFFFFF" Margin="18,0"/>

                    <Border Style="{StaticResource SettingsRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="{loc:Str Shortcuts.WorkflowPalette}"
                                           Style="{StaticResource SettingsRowLabelStyle}"/>
                                <TextBlock Text="{loc:Str Shortcuts.WorkflowPaletteHint}"
                                           Style="{StaticResource PageSubtitleStyle}"
                                           FontSize="12"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Width="320" VerticalAlignment="Center">
                                <ItemsControl ItemsSource="{Binding Settings.WorkflowPaletteHotkeys}"
                                              HorizontalAlignment="Right"
                                              Margin="0,0,0,6">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel HorizontalAlignment="Right"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource HotkeyChipStyle}" Margin="0,0,6,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding}" Foreground="{StaticResource TextBrush}" FontSize="12" VerticalAlignment="Center"/>
                                                    <Button Style="{StaticResource HotkeyChipCloseButtonStyle}"
                                                            Command="{Binding DataContext.Settings.RemoveWorkflowPaletteHotkeyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="{loc:Str Shortcuts.RemoveHotkey}"
                                                            AutomationProperties.Name="{loc:Str Shortcuts.RemoveHotkey}">
                                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="8" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <controls:HotkeyRecorderControl Hotkey="{Binding Settings.NewWorkflowPaletteHotkey, Mode=TwoWay}"
                                                                RecordedCommand="{Binding Settings.AddWorkflowPaletteHotkeyCommand}"
                                                                UseAddGlyph="True"
                                                                ToolTip="{loc:Str Shortcuts.AddHotkey}"
                                                                AllowModifierOnly="True"
                                                                HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Height="1" Background="#16FFFFFF" Margin="18,0"/>

                    <Border Style="{StaticResource SettingsRowBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="{loc:Str Shortcuts.RecorderToggle}"
                                           Style="{StaticResource SettingsRowLabelStyle}"/>
                                <TextBlock Text="{loc:Str Shortcuts.RecorderToggleHint}"
                                           Style="{StaticResource PageSubtitleStyle}"
                                           FontSize="12"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Width="320" VerticalAlignment="Center">
                                <ItemsControl ItemsSource="{Binding Settings.RecorderToggleHotkeys}"
                                              HorizontalAlignment="Right"
                                              Margin="0,0,0,6">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel HorizontalAlignment="Right"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource HotkeyChipStyle}" Margin="0,0,6,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding}" Foreground="{StaticResource TextBrush}" FontSize="12" VerticalAlignment="Center"/>
                                                    <Button Style="{StaticResource HotkeyChipCloseButtonStyle}"
                                                            Command="{Binding DataContext.Settings.RemoveRecorderToggleHotkeyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="{loc:Str Shortcuts.RemoveHotkey}"
                                                            AutomationProperties.Name="{loc:Str Shortcuts.RemoveHotkey}">
                                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="8" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <controls:HotkeyRecorderControl Hotkey="{Binding Settings.NewRecorderToggleHotkey, Mode=TwoWay}"
                                                                RecordedCommand="{Binding Settings.AddRecorderToggleHotkeyCommand}"
                                                                UseAddGlyph="True"
                                                                ToolTip="{loc:Str Shortcuts.AddHotkey}"
                                                                AllowModifierOnly="True"
                                                                HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

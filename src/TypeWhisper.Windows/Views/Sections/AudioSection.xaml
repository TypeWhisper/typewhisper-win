<UserControl x:Class="TypeWhisper.Windows.Views.Sections.AudioSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:TypeWhisper.Windows.ViewModels"
             xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,22,28,28" MaxWidth="980">
            <StackPanel Style="{StaticResource SettingsSectionStyle}">
                <TextBlock Text="{loc:Str Dictation.EngineSection}" Style="{StaticResource SettingsGroupTitleStyle}"/>
                <Border Style="{StaticResource SettingsGroupPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str Dictation.DefaultModel}"
                                           Style="{StaticResource SettingsRowLabelStyle}"/>
                                <ComboBox Grid.Column="1"
                                          Style="{StaticResource SettingsAlignedComboBoxStyle}"
                                          ItemsSource="{Binding ModelManager.AvailableModelOptions}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="FullId"
                                          SelectedValue="{Binding ModelManager.SelectedModelOptionId}"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Background="#18FFFFFF"/>

                        <Border Grid.Row="2"
                                Style="{StaticResource SettingsRowBorderStyle}"
                                Visibility="{Binding ModelManager.IsAccelerationSectionVisible, Converter={StaticResource BoolToVis}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Str Models.AccelerationLabel}"
                                               Style="{StaticResource SettingsRowLabelStyle}"/>
                                    <TextBlock Text="{loc:Str Models.AccelerationHint}"
                                               Style="{StaticResource HintStyle}"
                                               Margin="0,4,18,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Width="320"
                                            HorizontalAlignment="Right">
                                    <ComboBox Style="{StaticResource SettingsAlignedComboBoxStyle}"
                                              ItemsSource="{Binding ModelManager.AccelerationOptions}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding ModelManager.SelectedAccelerationOptionValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="{Binding ModelManager.AccelerationStatusText}"
                                               Style="{StaticResource SettingsCompactValueTextStyle}"
                                               Margin="0,6,0,0"
                                               TextAlignment="Right"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding ModelManager.AccelerationRestartMessage}"
                                               Style="{StaticResource HintStyle}"
                                               Margin="0,8,0,0"
                                               TextAlignment="Right"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding ModelManager.IsAccelerationRestartRequired, Converter={StaticResource BoolToVis}}"/>
                                    <ui:Button Content="{loc:Str Models.AccelerationRestartNow}"
                                               Command="{Binding ModelManager.RestartForAccelerationCommand}"
                                               Appearance="Primary"
                                               HorizontalAlignment="Right"
                                               Margin="0,8,0,0"
                                               Visibility="{Binding ModelManager.IsAccelerationRestartRequired, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3"
                                Background="#18FFFFFF"
                                Visibility="{Binding ModelManager.IsAccelerationSectionVisible, Converter={StaticResource BoolToVis}}"/>

                        <Border Grid.Row="4" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="240"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str Dictation.EngineLabel}"
                                           Style="{StaticResource SettingsRowLabelStyle}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ModelManager.ActiveProviderDisplayName}"
                                           Style="{StaticResource SettingsCompactValueTextStyle}"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="5" Background="#18FFFFFF"/>

                        <Border Grid.Row="6">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SettingsRowBorderStyle}">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ModelManager.IsActiveModelReady}" Value="True">
                                            <Setter Property="Background" Value="#1439B980"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="240"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str Dictation.ModelStatus}"
                                           Style="{StaticResource SettingsRowLabelStyle}"/>
                                <Border Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        CornerRadius="999"
                                        Padding="12,6">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1A2B3A4B"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ModelManager.IsActiveModelReady}" Value="True">
                                                    <Setter Property="Background" Value="#1E39B980"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <ProgressBar Width="38"
                                                     Height="4"
                                                     Margin="0,0,8,0"
                                                     VerticalAlignment="Center"
                                                     IsIndeterminate="True"
                                                     Foreground="{StaticResource AccentBrush}"
                                                     Visibility="{Binding ModelManager.IsActiveModelBusy, Converter={StaticResource BoolToVis}}"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding ModelManager.ActiveModelStatusText}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource SettingsValueTextStyle}">
                                                    <Setter Property="FontSize" Value="12.5"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ModelManager.IsActiveModelReady}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Style="{StaticResource SettingsSectionStyle}">
                <TextBlock Text="{loc:Str Recording.Microphone}" Style="{StaticResource SettingsGroupTitleStyle}"/>
                <Border Style="{StaticResource SettingsGroupPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str Dictation.InputDevice}"
                                           Style="{StaticResource SettingsRowLabelStyle}"/>
                                <Grid Grid.Column="1"
                                      Width="320"
                                      HorizontalAlignment="Right">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0"
                                              Style="{StaticResource SettingsCompactComboBoxStyle}"
                                              ItemsSource="{Binding Settings.Microphones}"
                                              DisplayMemberPath="Name"
                                              SelectedItem="{Binding Settings.SelectedMicrophoneItem, Mode=TwoWay}"/>
                                    <ui:Button Grid.Column="2"
                                               Width="36"
                                               Height="36"
                                               Command="{Binding Settings.AddMicrophonePriorityItemCommand}"
                                               Icon="{ui:SymbolIcon Add24}"
                                               Appearance="Secondary"
                                               AutomationProperties.Name="{loc:Str Microphone.AddPriorityItem}"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Background="#18FFFFFF"/>

                        <Border Grid.Row="2"
                                Style="{StaticResource SettingsRowBorderStyle}"
                                Visibility="{Binding Settings.HasMicrophonePriorityItems, Converter={StaticResource BoolToVis}}">
                            <ItemsControl ItemsSource="{Binding Settings.MicrophonePriorityItems}"
                                          Tag="{Binding Settings.ReorderMicrophonePriorityItemCommand}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#101923"
                                                BorderBrush="#18FFFFFF"
                                                BorderThickness="1"
                                                CornerRadius="7"
                                                Padding="10,8"
                                                Margin="0,0,0,6"
                                                AllowDrop="True"
                                                DragOver="OnMicrophonePriorityItemDragOver"
                                                Drop="OnMicrophonePriorityItemDrop">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="36"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        Width="24"
                                                        Height="28"
                                                        Margin="0,0,8,0"
                                                        Cursor="SizeAll"
                                                         Background="Transparent"
                                                         PreviewMouseLeftButtonDown="OnMicrophonePriorityDragHandleMouseDown"
                                                         PreviewMouseMove="OnMicrophonePriorityDragHandleMouseMove"
                                                         AutomationProperties.Name="{loc:Str Microphone.DragPriorityItem}">
                                                    <TextBlock Text="&#x22EE;&#x22EE;"
                                                               FontSize="15"
                                                               Foreground="{StaticResource HintBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Name}"
                                                           Style="{StaticResource SettingsCompactValueTextStyle}"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <ui:Button Grid.Column="2"
                                                           Width="30"
                                                           Height="30"
                                                           Command="{Binding DataContext.Settings.RemoveMicrophonePriorityItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Appearance="Secondary"
                                                            Padding="0"
                                                            AutomationProperties.Name="{loc:Str Microphone.RemovePriorityItem}">
                                                    <TextBlock Text="&#x00D7;"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ui:Button}}"/>
                                                </ui:Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <Border Grid.Row="3"
                                Background="#18FFFFFF"
                                Visibility="{Binding Settings.HasMicrophonePriorityItems, Converter={StaticResource BoolToVis}}"/>

                        <Border Grid.Row="4" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ui:Button Grid.Column="0"
                                           Content="{loc:Str Recording.Refresh}"
                                           Command="{Binding Settings.RefreshMicrophonesCommand}"
                                           Appearance="Secondary"
                                           Margin="0,0,12,0"/>
                                <ProgressBar Grid.Column="1"
                                             Minimum="0"
                                             Maximum="1"
                                             Value="{Binding Settings.PreviewLevel}"
                                             Height="8"
                                             VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Style="{StaticResource SettingsSectionStyle}">
                <TextBlock Text="{loc:Str General.Language}" Style="{StaticResource SettingsGroupTitleStyle}"/>
                <Border Style="{StaticResource SettingsGroupPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str Dictation.SpokenLanguage}"
                                           Style="{StaticResource SettingsRowLabelStyle}"/>
                                <ComboBox Grid.Column="1"
                                          Style="{StaticResource SettingsAlignedComboBoxStyle}"
                                          SelectedValue="{Binding Settings.Language}" SelectedValuePath="Tag">
                                    <ComboBoxItem Content="{loc:Str Dictation.AutoDetect}" Tag="auto"/>
                                    <ComboBoxItem Content="Deutsch" Tag="de"/>
                                    <ComboBoxItem Content="English" Tag="en"/>
                                    <ComboBoxItem Content="Français" Tag="fr"/>
                                    <ComboBoxItem Content="Español" Tag="es"/>
                                    <ComboBoxItem Content="中文" Tag="zh"/>
                                    <ComboBoxItem Content="Italiano" Tag="it"/>
                                    <ComboBoxItem Content="Português" Tag="pt"/>
                                    <ComboBoxItem Content="Nederlands" Tag="nl"/>
                                    <ComboBoxItem Content="Polski" Tag="pl"/>
                                    <ComboBoxItem Content="Čeština" Tag="cs"/>
                                    <ComboBoxItem Content="Svenska" Tag="sv"/>
                                    <ComboBoxItem Content="Dansk" Tag="da"/>
                                    <ComboBoxItem Content="Suomi" Tag="fi"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Background="#18FFFFFF"/>

                        <Border Grid.Row="2" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str General.TargetLanguage}"
                                           Style="{StaticResource SettingsRowLabelStyle}"/>
                                <ComboBox Grid.Column="1"
                                          Style="{StaticResource SettingsAlignedComboBoxStyle}"
                                          ItemsSource="{Binding Settings.TranslationTargetOptions}"
                                          SelectedValue="{Binding Settings.TranslationTargetLanguage}"
                                          SelectedValuePath="Code"
                                          DisplayMemberPath="DisplayName"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Style="{StaticResource SettingsSectionStyle}">
                <TextBlock Text="{loc:Str Dictation.SettingsSection}" Style="{StaticResource SettingsGroupTitleStyle}"/>
                <Border Style="{StaticResource SettingsGroupPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str Dictation.AutoPasteAfter}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding Settings.AutoPaste}" OnContent="" OffContent=""/>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Background="#18FFFFFF"/>
                        <Border Grid.Row="2" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str General.WhisperMode}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding Settings.WhisperModeEnabled}" OnContent="" OffContent=""/>
                            </Grid>
                        </Border>
                        <Border Grid.Row="3" Background="#18FFFFFF"/>
                        <Border Grid.Row="4" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str General.SoundFeedback}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding Settings.SoundFeedbackEnabled}" OnContent="" OffContent=""/>
                            </Grid>
                        </Border>
                        <Border Grid.Row="5" Background="#18FFFFFF"/>
                        <Border Grid.Row="6" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Str Dictation.ShortQuietAggressive}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                    <TextBlock Text="{loc:Str Dictation.ShortQuietAggressiveHint}"
                                               Style="{StaticResource HintStyle}"
                                               Margin="0,4,18,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <ui:ToggleSwitch Grid.Column="1"
                                                 IsChecked="{Binding Settings.TranscribeShortQuietClipsAggressively}"
                                                 OnContent=""
                                                 OffContent=""/>
                            </Grid>
                        </Border>
                        <Border Grid.Row="7" Background="#18FFFFFF"/>
                        <Border Grid.Row="8" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Str Dictation.NormalizeNumbers}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                    <TextBlock Text="{loc:Str Dictation.NormalizeNumbersHint}"
                                               Style="{StaticResource HintStyle}"
                                               Margin="0,4,18,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <ui:ToggleSwitch Grid.Column="1"
                                                 IsChecked="{Binding Settings.TranscriptionNumberNormalizationEnabled}"
                                                 OnContent=""
                                                 OffContent=""/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Style="{StaticResource SettingsSectionStyle}">
                <TextBlock Text="{loc:Str Dictation.SystemAudio}" Style="{StaticResource SettingsGroupTitleStyle}"/>
                <Border Style="{StaticResource SettingsGroupPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str Dictation.ReduceOtherAudio}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding Settings.AudioDuckingEnabled}" OnContent="" OffContent=""/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Background="#18FFFFFF"/>

                        <Border Grid.Row="2" Style="{StaticResource SettingsRowBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SettingsRowLabelStyle}">
                                    <Run Text="{loc:Str Dictation.DuckingLevel}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding Settings.AudioDuckingLevel, StringFormat='{}{0:P0}'}"/>
                                </TextBlock>
                                <Slider Minimum="0"
                                        Maximum="0.5"
                                        TickFrequency="0.05"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding Settings.AudioDuckingLevel}"
                                        Style="{StaticResource SettingsSliderStyle}"
                                        Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="3" Background="#18FFFFFF"/>

                        <Border Grid.Row="4" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str Dictation.PauseMediaPlayback}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding Settings.PauseMediaDuringRecording}" OnContent="" OffContent=""/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>

<UserControl x:Class="TypeWhisper.Windows.Views.Sections.AppearanceSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters"
             xmlns:models="clr-namespace:TypeWhisper.Core.Models;assembly=TypeWhisper.Core"
             xmlns:overlay="clr-namespace:TypeWhisper.Windows.Controls.Overlay"
             xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <conv:EnumEqualsConverter x:Key="EnumEquals"/>

            <Style x:Key="IndicatorStyleTileStyle" TargetType="RadioButton">
                <Setter Property="Foreground" Value="{StaticResource LabelBrush}"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Margin" Value="0,0,10,0"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="Tile"
                                    Background="#101820"
                                    BorderBrush="#243244"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="14,12"
                                    MinHeight="104">
                                <ContentPresenter HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Tile" Property="BorderBrush" Value="#42617E"/>
                                    <Setter TargetName="Tile" Property="Background" Value="#13202B"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Tile" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                    <Setter TargetName="Tile" Property="Background" Value="#17283A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,22,28,28" MaxWidth="980">
            <StackPanel Style="{StaticResource SettingsSectionStyle}">
                <TextBlock Text="{loc:Str Appearance.LayoutSection}" Style="{StaticResource SettingsGroupTitleStyle}"/>
                <Border Style="{StaticResource SettingsGroupPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource SettingsRowBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="{loc:Str Appearance.Style}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                <UniformGrid Columns="3" Margin="0,12,-10,0">
                                    <RadioButton GroupName="IndicatorStyle"
                                                 Style="{StaticResource IndicatorStyleTileStyle}"
                                                 IsChecked="{Binding Settings.IndicatorStyle, Mode=TwoWay, Converter={StaticResource EnumEquals}, ConverterParameter={x:Static models:IndicatorStyle.StatusIsland}}">
                                        <StackPanel>
                                            <Border Height="84"
                                                    Background="#0B1118"
                                                    BorderBrush="#203349"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    ClipToBounds="True"
                                                    Padding="10"
                                                    Margin="0,0,0,12">
                                                <Border Background="#E6121822"
                                                        BorderBrush="#22507BAA"
                                                        BorderThickness="1"
                                                        CornerRadius="17"
                                                        Padding="10,7"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        MinWidth="172">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <overlay:OverlayWidgetHost WidgetType="{Binding Settings.OverlayLeftWidget}"
                                                                                       VerticalAlignment="Center"
                                                                                       Margin="0,0,9,0"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{loc:Str Appearance.PreviewStatus}"
                                                                       Foreground="{StaticResource TextBrush}"
                                                                       FontSize="10.5"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                            <overlay:OverlayWidgetHost Grid.Column="2"
                                                                                       WidgetType="{Binding Settings.OverlayRightWidget}"
                                                                                       VerticalAlignment="Center"
                                                                                       Margin="9,0,0,0"/>
                                                        </Grid>
                                                        <TextBlock Text="{loc:Str Appearance.PreviewLiveText}"
                                                                   Foreground="{StaticResource HintBrush}"
                                                                   FontSize="{Binding Settings.LiveTranscriptionFontSize}"
                                                                   TextAlignment="Center"
                                                                   TextWrapping="NoWrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,5,0,0"
                                                                   Visibility="{Binding Settings.LiveTranscriptionEnabled, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                </Border>
                                            </Border>
                                            <TextBlock Text="{loc:Str Appearance.StyleStatusIsland}"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"/>
                                            <TextBlock Text="{loc:Str Appearance.StyleStatusIslandHint}"
                                                       Foreground="{StaticResource HintBrush}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Margin="0,7,0,0"/>
                                        </StackPanel>
                                    </RadioButton>

                                    <RadioButton GroupName="IndicatorStyle"
                                                 Style="{StaticResource IndicatorStyleTileStyle}"
                                                 IsChecked="{Binding Settings.IndicatorStyle, Mode=TwoWay, Converter={StaticResource EnumEquals}, ConverterParameter={x:Static models:IndicatorStyle.EdgeDock}}">
                                        <StackPanel>
                                            <Border Height="84"
                                                    Background="#0B1118"
                                                    BorderBrush="#203349"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    ClipToBounds="True"
                                                    Margin="0,0,0,12">
                                                <DockPanel LastChildFill="False">
                                                    <Border DockPanel.Dock="Top"
                                                            Background="#E6101824"
                                                            BorderBrush="#2B7EC8FF"
                                                            BorderThickness="0,0,0,1"
                                                            CornerRadius="0,0,9,9"
                                                            Padding="9,6"
                                                            MinHeight="30">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <overlay:OverlayWidgetHost Grid.Column="0"
                                                                                       WidgetType="{Binding Settings.OverlayLeftWidget}"
                                                                                       VerticalAlignment="Center"
                                                                                       Margin="0,0,8,0"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{loc:Str Appearance.PreviewStatus}"
                                                                       Foreground="{StaticResource TextBrush}"
                                                                       FontSize="10.5"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                            <overlay:OverlayWidgetHost Grid.Column="2"
                                                                                       WidgetType="{Binding Settings.OverlayRightWidget}"
                                                                                       VerticalAlignment="Center"
                                                                                       Margin="8,0,0,0"/>
                                                        </Grid>
                                                    </Border>
                                                    <TextBlock DockPanel.Dock="Top"
                                                               Text="{loc:Str Appearance.PreviewLiveText}"
                                                               Foreground="{StaticResource HintBrush}"
                                                               FontSize="{Binding Settings.LiveTranscriptionFontSize}"
                                                               TextAlignment="Center"
                                                               Margin="8,5,8,0"
                                                               Visibility="{Binding Settings.LiveTranscriptionEnabled, Converter={StaticResource BoolToVis}}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </DockPanel>
                                            </Border>
                                            <TextBlock Text="{loc:Str Appearance.StyleEdgeDock}"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"/>
                                            <TextBlock Text="{loc:Str Appearance.StyleEdgeDockHint}"
                                                       Foreground="{StaticResource HintBrush}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Margin="0,7,0,0"/>
                                        </StackPanel>
                                    </RadioButton>

                                    <RadioButton GroupName="IndicatorStyle"
                                                 Style="{StaticResource IndicatorStyleTileStyle}"
                                                 IsChecked="{Binding Settings.IndicatorStyle, Mode=TwoWay, Converter={StaticResource EnumEquals}, ConverterParameter={x:Static models:IndicatorStyle.CompactBadge}}">
                                        <StackPanel>
                                            <Border Height="58"
                                                    Background="#0B1118"
                                                    BorderBrush="#203349"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="10"
                                                    Margin="0,0,0,12">
                                                <Border Background="#E6181818"
                                                        BorderBrush="#2AFFFFFF"
                                                        BorderThickness="1"
                                                        CornerRadius="16"
                                                        Padding="10"
                                                        MinWidth="34"
                                                        MinHeight="34"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                    <Ellipse Width="8"
                                                             Height="8"
                                                             Fill="#FF4444"
                                                             VerticalAlignment="Center"/>
                                                </Border>
                                            </Border>
                                            <TextBlock Text="{loc:Str Appearance.StyleCompactBadge}"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"/>
                                            <TextBlock Text="{loc:Str Appearance.StyleCompactBadgeHint}"
                                                       Foreground="{StaticResource HintBrush}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Margin="0,7,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Background="#18FFFFFF"/>

                        <Border Grid.Row="2" Style="{StaticResource SettingsRowBorderStyle}">
                            <StackPanel>
                                <Grid x:Name="LivePreviewToggleSettingsRow">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{loc:Str Appearance.LivePreview}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                        <TextBlock Text="{loc:Str Appearance.LivePreviewHint}"
                                                   Style="{StaticResource HintStyle}"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <ui:ToggleSwitch Grid.Column="1"
                                                     IsChecked="{Binding Settings.LiveTranscriptionEnabled}"
                                                     OnContent=""
                                                     OffContent=""
                                                     VerticalAlignment="Center"/>
                                </Grid>

                                <Grid x:Name="LiveTextSizeSettingsRow">
                                    <Grid.Style>
                                        <Style TargetType="{x:Type Grid}">
                                            <Setter Property="Margin" Value="0,16,0,0"/>
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Settings.IndicatorStyle}" Value="{x:Static models:IndicatorStyle.CompactBadge}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Str Appearance.LiveTextSize}"
                                               Style="{StaticResource SettingsRowLabelStyle}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Settings.LiveTranscriptionFontSizeText}"
                                               Foreground="{StaticResource HintBrush}"
                                               FontSize="12"
                                               VerticalAlignment="Center"/>
                                    <Slider Grid.Row="1"
                                            Grid.ColumnSpan="2"
                                            Minimum="10"
                                            Maximum="18"
                                            SmallChange="0.5"
                                            LargeChange="1"
                                            TickFrequency="0.5"
                                            IsSnapToTickEnabled="True"
                                            IsMoveToPointEnabled="True"
                                            Value="{Binding Settings.LiveTranscriptionFontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Style="{StaticResource SettingsSliderStyle}"
                                            Margin="0,10,0,0"/>
                                </Grid>

                                <Grid x:Name="OnlineAsrBatchLivePreviewSettingsRow"
                                      Margin="0,16,0,0"
                                      IsEnabled="{Binding Settings.LiveTranscriptionEnabled}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{loc:Str Appearance.OnlineAsrBatchLivePreview}"
                                                   Style="{StaticResource SettingsRowLabelStyle}"/>
                                        <TextBlock Text="{loc:Str Appearance.OnlineAsrBatchLivePreviewHint}"
                                                   Style="{StaticResource HintStyle}"
                                                   Margin="0,5,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ui:ToggleSwitch Grid.Column="1"
                                                     IsChecked="{Binding Settings.OnlineAsrBatchLiveTranscriptionEnabled}"
                                                     OnContent=""
                                                     OffContent=""
                                                     VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,16,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Str Appearance.AutoHideDelay}"
                                               Style="{StaticResource SettingsRowLabelStyle}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Settings.PreviewBubbleAutoHideSecondsText}"
                                               Foreground="{StaticResource HintBrush}"
                                               FontSize="12"
                                               VerticalAlignment="Center"/>
                                    <Slider Grid.Row="1"
                                            Grid.ColumnSpan="2"
                                            Minimum="0"
                                            Maximum="5"
                                            SmallChange="0.25"
                                            LargeChange="0.5"
                                            TickFrequency="0.25"
                                            IsSnapToTickEnabled="True"
                                            IsMoveToPointEnabled="True"
                                            Value="{Binding Settings.PreviewBubbleAutoHideSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Style="{StaticResource SettingsSliderStyle}"
                                            Margin="0,10,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="3" Background="#18FFFFFF"/>

                        <Border Grid.Row="4" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str General.Position}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                <ComboBox Grid.Column="1"
                                          Style="{StaticResource SettingsAlignedComboBoxStyle}"
                                          SelectedValue="{Binding Settings.OverlayPosition}"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Content="{loc:Str General.PositionTop}" Tag="{x:Static models:OverlayPosition.Top}"/>
                                    <ComboBoxItem Content="{loc:Str General.PositionBottom}" Tag="{x:Static models:OverlayPosition.Bottom}"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <Border x:Name="WidgetSettingsSeparatorTop"
                                Grid.Row="5"
                                Background="#18FFFFFF">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Settings.IndicatorStyle}" Value="{x:Static models:IndicatorStyle.CompactBadge}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <Border x:Name="LeftWidgetSettingsRow"
                                Grid.Row="6">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}" BasedOn="{StaticResource SettingsRowBorderStyle}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Settings.IndicatorStyle}" Value="{x:Static models:IndicatorStyle.CompactBadge}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str Appearance.LeftContent}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                <ComboBox Grid.Column="1"
                                          Style="{StaticResource SettingsAlignedComboBoxStyle}"
                                          ItemsSource="{Binding Settings.WidgetOptions}"
                                          SelectedValue="{Binding Settings.OverlayLeftWidget}"
                                          SelectedValuePath="Value"
                                          DisplayMemberPath="DisplayName"/>
                            </Grid>
                        </Border>

                        <Border x:Name="WidgetSettingsSeparatorMiddle"
                                Grid.Row="7"
                                Background="#18FFFFFF">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Settings.IndicatorStyle}" Value="{x:Static models:IndicatorStyle.CompactBadge}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <Border x:Name="RightWidgetSettingsRow"
                                Grid.Row="8">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}" BasedOn="{StaticResource SettingsRowBorderStyle}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Settings.IndicatorStyle}" Value="{x:Static models:IndicatorStyle.CompactBadge}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str Appearance.RightContent}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                <ComboBox Grid.Column="1"
                                          Style="{StaticResource SettingsAlignedComboBoxStyle}"
                                          ItemsSource="{Binding Settings.WidgetOptions}"
                                          SelectedValue="{Binding Settings.OverlayRightWidget}"
                                          SelectedValuePath="Value"
                                          DisplayMemberPath="DisplayName"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Style="{StaticResource SettingsSectionStyle}" Visibility="Collapsed">
                <TextBlock Text="{loc:Str Appearance.PreviewTitle}" Style="{StaticResource SettingsGroupTitleStyle}"/>
                <Border Style="{StaticResource SettingsGroupPanelStyle}">
                    <StackPanel Margin="16">
                        <Border Background="#120C1118" CornerRadius="14" Padding="24" MinHeight="190" Margin="0,0,0,18" Visibility="Collapsed">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{loc:Str Appearance.PreviewTitle}"
                                           Foreground="{StaticResource HintBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,16"/>

                                <Grid Height="118" ClipToBounds="True">
                                    <Viewbox Stretch="Uniform"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             MaxWidth="660"
                                             MaxHeight="112">
                                        <Border Width="660"
                                                MinHeight="118"
                                                Background="Transparent"
                                                Padding="12">
                                            <overlay:IndicatorStyleHost HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                        </Border>
                                    </Viewbox>
                                </Grid>

                                <TextBlock Text="{loc:Str Appearance.PreviewHint}"
                                           Foreground="{StaticResource HintBrush}"
                                           FontSize="11"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center"
                                           MaxWidth="420"
                                           Margin="0,16,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#120C1118" CornerRadius="14" Padding="28" MinHeight="210" Margin="0,0,0,18" Visibility="Collapsed">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{loc:Str Appearance.PreviewTitle}"
                                           Foreground="{StaticResource HintBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,14"/>

                                <Grid MinHeight="118">
                                    <Border Background="#E6121822"
                                            BorderBrush="#22507BAA"
                                            BorderThickness="1"
                                            CornerRadius="26"
                                            Padding="16,12"
                                            HorizontalAlignment="Center"
                                            MinWidth="340">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Settings.IndicatorStyle}" Value="{x:Static models:IndicatorStyle.StatusIsland}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{loc:Str Appearance.PreviewLiveText}"
                                                       Foreground="{StaticResource HintBrush}"
                                                       FontSize="11"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,8"
                                                       Visibility="{Binding Settings.LiveTranscriptionEnabled, Converter={StaticResource BoolToVis}}"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <overlay:OverlayWidgetHost Grid.Column="0"
                                                                           WidgetType="{Binding Settings.OverlayLeftWidget}"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,12,0"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{loc:Str Appearance.PreviewStatus}"
                                                           Foreground="{StaticResource TextBrush}"
                                                           FontSize="14"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                <overlay:OverlayWidgetHost Grid.Column="2"
                                                                           WidgetType="{Binding Settings.OverlayRightWidget}"
                                                                           VerticalAlignment="Center"
                                                                           Margin="12,0,0,0"/>
                                            </Grid>
                                            <TextBlock Text="{loc:Str Appearance.PreviewLiveTextTail}"
                                                       Foreground="{StaticResource HintBrush}"
                                                       FontSize="11"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Margin="0,8,0,0"
                                                       Visibility="{Binding Settings.LiveTranscriptionEnabled, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#E6101824"
                                            BorderBrush="#2B7EC8FF"
                                            BorderThickness="1"
                                            CornerRadius="0,0,18,18"
                                            Padding="16,12"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Top"
                                            MinWidth="430">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Settings.IndicatorStyle}" Value="{x:Static models:IndicatorStyle.EdgeDock}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{loc:Str Appearance.PreviewLiveText}"
                                                       Foreground="{StaticResource HintBrush}"
                                                       FontSize="11"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,8"
                                                       Visibility="{Binding Settings.LiveTranscriptionEnabled, Converter={StaticResource BoolToVis}}"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <overlay:OverlayWidgetHost Grid.Column="0"
                                                                           WidgetType="{Binding Settings.OverlayLeftWidget}"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,12,0"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{loc:Str Appearance.PreviewStatus}"
                                                           Foreground="{StaticResource TextBrush}"
                                                           FontSize="14"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                <overlay:OverlayWidgetHost Grid.Column="2"
                                                                           WidgetType="{Binding Settings.OverlayRightWidget}"
                                                                           VerticalAlignment="Center"
                                                                           Margin="12,0,0,0"/>
                                            </Grid>
                                            <TextBlock Text="{loc:Str Appearance.PreviewLiveTextTail}"
                                                       Foreground="{StaticResource HintBrush}"
                                                       FontSize="11"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Margin="0,8,0,0"
                                                       Visibility="{Binding Settings.LiveTranscriptionEnabled, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#E6181818"
                                            BorderBrush="#2AFFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            Padding="10"
                                            MinWidth="34"
                                            MinHeight="34"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Settings.IndicatorStyle}" Value="{x:Static models:IndicatorStyle.CompactBadge}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <overlay:IndicatorWidget HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>

                                <TextBlock Text="{loc:Str Appearance.PreviewHint}"
                                           Foreground="{StaticResource HintBrush}"
                                           FontSize="11"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center"
                                           MaxWidth="360"
                                           Margin="0,14,0,0"/>
                            </StackPanel>
                        </Border>
                        <Grid Margin="10,0,10,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{loc:Str Appearance.AutoHideDelay}"
                                       Style="{StaticResource SettingsRowLabelStyle}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Settings.PreviewBubbleAutoHideSecondsText}"
                                       Foreground="{StaticResource HintBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                            <Slider Grid.Row="1"
                                    Grid.ColumnSpan="2"
                                    Minimum="0"
                                    Maximum="5"
                                    SmallChange="0.25"
                                    LargeChange="0.5"
                                    TickFrequency="0.25"
                                    IsSnapToTickEnabled="True"
                                    IsMoveToPointEnabled="True"
                                    Value="{Binding Settings.PreviewBubbleAutoHideSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Style="{StaticResource SettingsSliderStyle}"
                                    Margin="0,12,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>

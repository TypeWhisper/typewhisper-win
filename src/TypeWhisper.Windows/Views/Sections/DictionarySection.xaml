<UserControl x:Class="TypeWhisper.Windows.Views.Sections.DictionarySection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:TypeWhisper.Windows.Converters"
             xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization"
             AutomationProperties.AutomationId="SettingsSection.Dictionary">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
            <converters:LocalizedFormatConverter x:Key="LocalizedFormat"/>
            <converters:IntegerEqualsConverter x:Key="IntegerEquals"/>

            <!-- Small icon button -->
            <Style x:Key="IconButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource HintBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Width" Value="28"/>
                <Setter Property="Height" Value="28"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#40FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Segmented Button Left Style -->
            <Style x:Key="SegmentedButtonLeftStyle" TargetType="RadioButton">
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="Bd" Background="#2A2A2A"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,1,0,1"
                                    CornerRadius="6,0,0,6" Padding="10,6">
                                <TextBlock x:Name="Txt" Text="{TemplateBinding Content}"
                                           FontSize="12" FontWeight="Medium"
                                           Foreground="{StaticResource HintBrush}"
                                           HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#3A2A1A"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#5A3A1A"/>
                                    <Setter TargetName="Txt" Property="Foreground" Value="#D4915B"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#333333"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsChecked" Value="True"/>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bd" Property="Background" Value="#3A2A1A"/>
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Segmented Button Right Style -->
            <Style x:Key="SegmentedButtonRightStyle" TargetType="RadioButton">
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="Bd" Background="#2A2A2A"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="0,6,6,0" Padding="10,6">
                                <TextBlock x:Name="Txt" Text="{TemplateBinding Content}"
                                           FontSize="12" FontWeight="Medium"
                                           Foreground="{StaticResource HintBrush}"
                                           HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#2A3A5A"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#1A3A5A"/>
                                    <Setter TargetName="Txt" Property="Foreground" Value="#5B9BD5"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#333333"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsChecked" Value="True"/>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bd" Property="Background" Value="#2A3A5A"/>
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
    <DockPanel Margin="24">
        <DockPanel.Style>
            <Style TargetType="DockPanel">
                <Setter Property="IsEnabled" Value="True"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Dictionary.Training.IsOpen}" Value="True">
                        <Setter Property="IsEnabled" Value="False"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </DockPanel.Style>
        <TextBlock DockPanel.Dock="Top" Text="{loc:Str Dictionary.Title}" Style="{StaticResource SectionHeaderStyle}"/>

        <Border DockPanel.Dock="Top" Margin="0,0,0,12"
                Background="{StaticResource InputBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="10" Padding="14,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{loc:Str Dictionary.BoostingToggle}"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="{loc:Str Dictionary.BoostingHint}"
                               Foreground="{StaticResource HintBrush}"
                               FontSize="12" TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding Dictionary.VocabularyBoostingStatusText}"
                               Foreground="{StaticResource HintBrush}"
                               FontSize="12" Margin="0,6,0,0"/>
                </StackPanel>

                <ui:ToggleSwitch Grid.Column="1"
                                 IsChecked="{Binding Dictionary.VocabularyBoostingEnabled}"
                                 AutomationProperties.AutomationId="DictionaryVocabularyBoosting"
                                 AutomationProperties.Name="{loc:Str Dictionary.BoostingToggle}"
                                 VerticalAlignment="Top"
                                 Margin="12,0,0,0"/>
            </Grid>
        </Border>

        <!-- Tabs -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton Content="{loc:Str Dictionary.TabAll}" GroupName="DictTab"
                         IsChecked="{Binding Dictionary.SelectedTab, Converter={StaticResource IntegerEquals}, ConverterParameter=0, Mode=TwoWay}"
                         AutomationProperties.AutomationId="DictionaryTabAll"
                         Style="{StaticResource TabRadioStyle}"/>
            <RadioButton Content="{loc:Str Dictionary.TabTerms}" GroupName="DictTab"
                         IsChecked="{Binding Dictionary.SelectedTab, Converter={StaticResource IntegerEquals}, ConverterParameter=1, Mode=TwoWay}"
                         AutomationProperties.AutomationId="DictionaryTabTerms"
                         Style="{StaticResource TabRadioStyle}"/>
            <RadioButton Content="{loc:Str Dictionary.TabCorrections}" GroupName="DictTab"
                         IsChecked="{Binding Dictionary.SelectedTab, Converter={StaticResource IntegerEquals}, ConverterParameter=2, Mode=TwoWay}"
                         AutomationProperties.AutomationId="DictionaryTabCorrections"
                         Style="{StaticResource TabRadioStyle}"/>
            <RadioButton Content="{loc:Str Dictionary.TabAutoLearned}" GroupName="DictTab"
                         IsChecked="{Binding Dictionary.SelectedTab, Converter={StaticResource IntegerEquals}, ConverterParameter=3, Mode=TwoWay}"
                         AutomationProperties.AutomationId="DictionaryTabAutoLearned"
                         Style="{StaticResource TabRadioStyle}"/>
            <RadioButton Content="{loc:Str Dictionary.TabPacks}" GroupName="DictTab"
                         IsChecked="{Binding Dictionary.SelectedTab, Converter={StaticResource IntegerEquals}, ConverterParameter=4, Mode=TwoWay}"
                         AutomationProperties.AutomationId="DictionaryTabPacks"
                         Style="{StaticResource TabRadioStyle}"/>
        </StackPanel>

        <!-- Search Bar (hidden on Packs tab) -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Dictionary.SelectedTab}" Value="4">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search field with icon -->
            <Border Grid.Column="0" Background="{StaticResource InputBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search icon -->
                    <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                               FontSize="14" Foreground="{StaticResource HintBrush}"
                               VerticalAlignment="Center" Margin="10,0,6,0"/>

                    <!-- Placeholder -->
                    <TextBlock Grid.Column="1" Text="{loc:Str Dictionary.SearchPlaceholder}"
                               Foreground="{StaticResource HintBrush}" FontSize="13"
                               VerticalAlignment="Center" IsHitTestVisible="False"
                               Visibility="{Binding Dictionary.HasSearchText, Converter={StaticResource InverseBoolToVis}}"/>

                    <!-- Search TextBox -->
                    <TextBox Grid.Column="1"
                             Text="{Binding Dictionary.SearchText, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.AutomationId="DictionarySearch"
                             AutomationProperties.Name="{loc:Str Dictionary.SearchPlaceholder}"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource TextBrush}" FontSize="13"
                             VerticalAlignment="Center" Padding="0,8"
                             CaretBrush="{StaticResource TextBrush}"/>

                    <!-- Clear button -->
                    <Button Grid.Column="2" Style="{StaticResource IconButtonStyle}"
                            Command="{Binding Dictionary.ClearSearchCommand}"
                            AutomationProperties.AutomationId="DictionaryClearSearch"
                            AutomationProperties.Name="{loc:Str Dictionary.ClearSearch}"
                            Visibility="{Binding Dictionary.HasSearchText, Converter={StaticResource BoolToVis}}"
                            ToolTip="{loc:Str Dictionary.ClearSearch}" Margin="0,0,4,0">
                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Foreground="{StaticResource HintBrush}"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Entry count -->
            <TextBlock Grid.Column="1" Foreground="{StaticResource HintBrush}" FontSize="12"
                       VerticalAlignment="Center" Margin="12,0,0,0">
                <Run Text="{Binding Dictionary.EntryCount, Mode=OneWay}"/>
                <Run Text="{loc:Str Dictionary.EntryCount}"/>
            </TextBlock>

            <ui:Button Grid.Column="2" Command="{Binding Dictionary.Training.OpenCommand}"
                       Click="OpenTraining_Click" Appearance="Secondary"
                       Visibility="{Binding Dictionary.Training, Converter={StaticResource BoolToVis}}"
                       AutomationProperties.AutomationId="DictionaryTrainingOpen"
                       AutomationProperties.Name="{loc:Str Dictionary.TrainingOpen}"
                       Margin="10,0,0,0" Padding="10,5">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE720;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{loc:Str Dictionary.TrainingOpen}"/>
                </StackPanel>
            </ui:Button>

            <Button Grid.Column="3" Content="{loc:Str Dictionary.DataManagement}"
                    AutomationProperties.AutomationId="DictionaryDataManagement"
                    AutomationProperties.Name="{loc:Str Dictionary.DataManagement}"
                    Margin="10,0,0,0" Padding="10,5" Click="DataManagement_Click">
                <Button.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="{loc:Str Dictionary.ClearAutoLearned}"
                                  AutomationProperties.AutomationId="DictionaryClearAutoLearned"
                                  AutomationProperties.Name="{loc:Str Dictionary.ClearAutoLearned}"
                                  Command="{Binding Dictionary.ClearAutoLearnedCorrectionsCommand}"/>
                        <MenuItem Header="{loc:Str Dictionary.ResetCustomDictionary}"
                                  AutomationProperties.AutomationId="DictionaryResetCustom"
                                  AutomationProperties.Name="{loc:Str Dictionary.ResetCustomDictionary}"
                                  Command="{Binding Dictionary.ResetCustomDictionaryCommand}"/>
                        <Separator/>
                        <MenuItem Header="{loc:Str Dictionary.DeactivateAllPacks}"
                                  AutomationProperties.AutomationId="DictionaryDeactivateAllPacks"
                                  AutomationProperties.Name="{loc:Str Dictionary.DeactivateAllPacks}"
                                  Command="{Binding Dictionary.DeactivateAllTermPacksCommand}"/>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
        </Grid>

        <!-- Add Entry Form (hidden on Packs tab) -->
        <Border DockPanel.Dock="Bottom" Margin="0,12,0,0"
                Background="{StaticResource InputBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="10" Padding="16,14">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Dictionary.SelectedTab}" Value="4">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <!-- Input fields row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Original field with watermark -->
                    <Grid Grid.Column="0">
                        <TextBox Text="{Binding Dictionary.NewOriginal, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.AutomationId="DictionaryNewOriginal"
                                 AutomationProperties.Name="{loc:Str Dictionary.OriginalPlaceholder}"
                                 Style="{StaticResource InputTextBoxStyle}" x:Name="OriginalBox"/>
                        <TextBlock Text="{loc:Str Dictionary.OriginalPlaceholder}" Foreground="{StaticResource HintBrush}"
                                   FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"
                                   IsHitTestVisible="False" Opacity="0.5">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=OriginalBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Arrow between fields -->
                    <TextBlock Grid.Column="1" Text="→" Foreground="{StaticResource HintBrush}"
                               FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="8,0" Opacity="0.4"/>

                    <!-- Replacement field with watermark -->
                    <Grid Grid.Column="2">
                        <TextBox Text="{Binding Dictionary.NewReplacement, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.AutomationId="DictionaryNewReplacement"
                                 AutomationProperties.Name="{loc:Str Dictionary.ReplacementPlaceholder}"
                                 Style="{StaticResource InputTextBoxStyle}" x:Name="ReplacementBox"/>
                        <TextBlock Foreground="{StaticResource HintBrush}"
                                   FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"
                                   IsHitTestVisible="False" Opacity="0.5">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Text" Value="{loc:Str Dictionary.ReplacementPlaceholder}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=ReplacementBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Segmented Type Buttons -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="8,0,0,0"
                                VerticalAlignment="Center">
                        <RadioButton Content="{loc:Str Dictionary.Correction}" GroupName="EntryType"
                                     IsChecked="{Binding Dictionary.IsNewTypeCorrection}"
                                     AutomationProperties.AutomationId="DictionaryNewTypeCorrection"
                                     Style="{StaticResource SegmentedButtonLeftStyle}"/>
                        <RadioButton Content="{loc:Str Dictionary.Term}" GroupName="EntryType"
                                     IsChecked="{Binding Dictionary.IsNewTypeTerm}"
                                     AutomationProperties.AutomationId="DictionaryNewTypeTerm"
                                     Style="{StaticResource SegmentedButtonRightStyle}"/>
                    </StackPanel>

                    <!-- Case sensitive (subtle icon button) -->
                    <Border Grid.Column="4" CornerRadius="6" Margin="6,0,0,0"
                            VerticalAlignment="Center" Cursor="Hand"
                            ToolTip="{loc:Str Dictionary.CaseSensitive}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="5,4"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Dictionary.NewCaseSensitive}" Value="True">
                                        <Setter Property="Background" Value="#2A3A2A"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <CheckBox IsChecked="{Binding Dictionary.NewCaseSensitive}"
                                  AutomationProperties.AutomationId="DictionaryNewCaseSensitive"
                                  AutomationProperties.Name="{loc:Str Dictionary.CaseSensitive}"
                                  Style="{StaticResource InputCheckBoxStyle}"
                                  Content="Aa" FontSize="12" Opacity="0.6"/>
                    </Border>

                    <!-- Add button -->
                    <ui:Button Grid.Column="5" Command="{Binding Dictionary.AddEntryCommand}"
                            AutomationProperties.AutomationId="DictionaryAddEntry"
                            AutomationProperties.Name="{loc:Str Dictionary.Add}"
                            Appearance="Primary" Padding="14,8"
                            Margin="8,0,0,0" VerticalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{loc:Str Dictionary.Add}" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Edit Overlay + Lists -->
        <Grid>
            <!-- Entries List (Tabs 0-3) -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          AutomationProperties.AutomationId="DictionaryEntries">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource SettingsScrollBarStyle}"/>
                </ScrollViewer.Resources>
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource TouchScrollViewerStyle}">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Dictionary.SelectedTab}" Value="4">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>

                <StackPanel>
                    <!-- Rich Empty State -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,48,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Dictionary.EntryCount}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Icon -->
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="48"
                                   Foreground="{StaticResource HintBrush}" Opacity="0.4"
                                   HorizontalAlignment="Center" Margin="0,0,0,12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#xE82D;"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Dictionary.SelectedTab}" Value="1">
                                            <Setter Property="Text" Value="&#xE8F1;"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Dictionary.SelectedTab}" Value="2">
                                            <Setter Property="Text" Value="&#xE8AC;"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Dictionary.SelectedTab}" Value="3">
                                            <Setter Property="Text" Value="&#xE7C3;"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Dictionary.HasSearchText}" Value="True">
                                            <Setter Property="Text" Value="&#xE721;"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Heading -->
                        <TextBlock Foreground="{StaticResource TextBrush}" FontSize="16"
                                   FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,6">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{loc:Str Dictionary.EmptyTitle}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Dictionary.SelectedTab}" Value="1">
                                            <Setter Property="Text" Value="{loc:Str Dictionary.EmptyTermsTitle}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Dictionary.SelectedTab}" Value="2">
                                            <Setter Property="Text" Value="{loc:Str Dictionary.EmptyCorrectionsTitle}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Dictionary.SelectedTab}" Value="3">
                                            <Setter Property="Text" Value="{loc:Str Dictionary.EmptyAutoLearnedTitle}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Dictionary.HasSearchText}" Value="True">
                                            <Setter Property="Text" Value="{loc:Str Dictionary.EmptySearchTitle}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Subtitle -->
                        <TextBlock Foreground="{StaticResource HintBrush}" FontSize="13"
                                   Opacity="0.6" HorizontalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center" MaxWidth="320">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{loc:Str Dictionary.EmptySubtitle}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Dictionary.SelectedTab}" Value="1">
                                            <Setter Property="Text" Value="{loc:Str Dictionary.EmptyTermsSubtitle}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Dictionary.SelectedTab}" Value="2">
                                            <Setter Property="Text" Value="{loc:Str Dictionary.EmptyCorrectionsSubtitle}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Dictionary.SelectedTab}" Value="3">
                                            <Setter Property="Text" Value="{loc:Str Dictionary.EmptyAutoLearnedSubtitle}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Dictionary.HasSearchText}" Value="True">
                                            <Setter Property="Text" Value="{loc:Str Dictionary.EmptySearchSubtitle}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- Entry Cards -->
                    <ItemsControl ItemsSource="{Binding Dictionary.VisibleEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,6">
                                    <!-- Terms, empty corrections, and single-alias corrections stay lightweight. -->
                                    <Border Visibility="{Binding IsGroupedCorrection, Converter={StaticResource InverseBoolToVis}}">
                                        <Border DataContext="{Binding PrimaryEntry}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Opacity" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                            <Setter Property="Opacity" Value="0.5"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border Background="{StaticResource InputBackgroundBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="3"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" CornerRadius="8,0,0,8">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#5B9BD5"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding EntryType}" Value="Correction">
                                                                        <Setter Property="Background" Value="#D4915B"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                    <Grid Grid.Column="1" Margin="12,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                                                        VerticalAlignment="Center">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Background" Value="#2A3A5A"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding EntryType}" Value="Correction">
                                                                                    <Setter Property="Background" Value="#3A2A1A"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock FontSize="11" FontWeight="Medium">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Foreground" Value="#5B9BD5"/>
                                                                                <Setter Property="Text" Value="{loc:Str Dictionary.Term}"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding EntryType}" Value="Correction">
                                                                                        <Setter Property="Foreground" Value="#D4915B"/>
                                                                                        <Setter Property="Text" Value="{loc:Str Dictionary.Correction}"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Border>
                                                                <TextBlock Text="{Binding Original}" Foreground="{StaticResource TextBrush}"
                                                                           FontSize="13" VerticalAlignment="Center"/>
                                                                <StackPanel Orientation="Horizontal" Margin="6,0,0,0"
                                                                            VerticalAlignment="Center"
                                                                            Visibility="{Binding Replacement, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                                                                    <TextBlock Text="→" Foreground="#D4915B" FontSize="13" FontWeight="Medium"/>
                                                                    <TextBlock Text="{Binding Replacement}" Foreground="{StaticResource TextBrush}"
                                                                               FontSize="13" FontWeight="Medium" Margin="4,0,0,0"/>
                                                                </StackPanel>
                                                                <Border CornerRadius="3" Padding="4,1" Margin="8,0,0,0"
                                                                        Background="#333333" VerticalAlignment="Center"
                                                                        Visibility="{Binding CaseSensitive, Converter={StaticResource BoolToVis}}">
                                                                    <TextBlock Text="Aa" FontSize="10" Foreground="{StaticResource HintBrush}"
                                                                               ToolTip="{loc:Str Dictionary.CaseSensitive}"/>
                                                                </Border>
                                                                <Border CornerRadius="3" Padding="5,1" Margin="8,0,0,0"
                                                                        Background="#183B35" VerticalAlignment="Center">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Source}" Value="AutoLearned">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock Text="{loc:Str Dictionary.AutoLearned}" FontSize="10" Foreground="#70C1AE"/>
                                                                </Border>
                                                            </StackPanel>
                                                            <TextBlock FontSize="11" Foreground="{StaticResource HintBrush}" Margin="0,2,0,0">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding UsageCount}" Value="0">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                                <TextBlock.Text>
                                                                    <MultiBinding Converter="{StaticResource LocalizedFormat}">
                                                                        <Binding Source="{x:Static loc:Loc.Instance}" Path="[Dictionary.UsageCount]"/>
                                                                        <Binding Path="UsageCount"/>
                                                                    </MultiBinding>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Button Style="{StaticResource IconButtonStyle}"
                                                                    AutomationProperties.AutomationId="{Binding Id, StringFormat=DictionaryAddAlias.{0}}"
                                                                    AutomationProperties.Name="{loc:Str Dictionary.AddAlias}"
                                                                    ToolTip="{loc:Str Dictionary.AddAlias}"
                                                                    Visibility="{Binding Replacement, Converter={StaticResource BoolToVis}}"
                                                                    Command="{Binding DataContext.Dictionary.PrepareAliasCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding Replacement}"
                                                                    Click="PrepareAlias_Click">
                                                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                            </Button>
                                                            <Button Style="{StaticResource IconButtonStyle}" ToolTip="{loc:Str Dictionary.Edit}"
                                                                    AutomationProperties.AutomationId="{Binding Id, StringFormat=DictionaryEdit.{0}}"
                                                                    AutomationProperties.Name="{loc:Str Dictionary.Edit}"
                                                                    Command="{Binding DataContext.Dictionary.StartEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}">
                                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                            </Button>
                                                            <ui:ToggleSwitch IsChecked="{Binding IsEnabled, Mode=OneWay}" Margin="4,0"
                                                                             AutomationProperties.AutomationId="{Binding Id, StringFormat=DictionaryEnabled.{0}}"
                                                                             AutomationProperties.Name="{Binding Original}"
                                                                             Command="{Binding DataContext.Dictionary.ToggleEnabledCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                             CommandParameter="{Binding}"/>
                                                            <Button Style="{StaticResource IconButtonStyle}" ToolTip="{loc:Str Dictionary.Delete}"
                                                                    AutomationProperties.AutomationId="{Binding Id, StringFormat=DictionaryDelete.{0}}"
                                                                    AutomationProperties.Name="{loc:Str Dictionary.Delete}"
                                                                    Command="{Binding DataContext.Dictionary.DeleteEntryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}">
                                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                                           Foreground="{StaticResource DangerBrush}"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </Border>
                                    </Border>

                                    <!-- Multi-alias corrections use the same compact card shape as single entries. -->
                                    <Border Background="{StaticResource InputBackgroundBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="8" ClipToBounds="True"
                                            Visibility="{Binding IsGroupedCorrection, Converter={StaticResource BoolToVis}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#D4915B" CornerRadius="8,0,0,8"/>
                                            <StackPanel Grid.Column="1">
                                                <Grid Margin="12,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Background="#3A2A1A" CornerRadius="4"
                                                            Padding="6,2" Margin="0,0,8,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{loc:Str Dictionary.Correction}" Foreground="#D4915B"
                                                                   FontSize="11" FontWeight="Medium"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="1" Text="{Binding Replacement}"
                                                               Foreground="{StaticResource TextBrush}" FontSize="13"
                                                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <Border Grid.Column="2" Background="#252B33" CornerRadius="10"
                                                            Padding="7,2" Margin="8,0,4,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Entries.Count}" Foreground="{StaticResource HintBrush}"
                                                                   FontSize="10" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <Button Grid.Column="3" Style="{StaticResource IconButtonStyle}"
                                                            AutomationProperties.AutomationId="{Binding Replacement, StringFormat=DictionaryAddGroupedAlias.{0}}"
                                                            AutomationProperties.Name="{loc:Str Dictionary.AddAlias}"
                                                            ToolTip="{loc:Str Dictionary.AddAlias}"
                                                            Command="{Binding DataContext.Dictionary.PrepareAliasCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding Replacement}"
                                                            Click="PrepareAlias_Click">
                                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                    </Button>
                                                    <Button Grid.Column="4" Style="{StaticResource IconButtonStyle}"
                                                            AutomationProperties.AutomationId="{Binding Replacement, StringFormat=DictionaryToggleAliases.{0}}"
                                                            ToolTip="{loc:Str Dictionary.ToggleAliases}"
                                                            AutomationProperties.Name="{loc:Str Dictionary.ToggleAliases}"
                                                            Command="{Binding ToggleCommand}">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="&#xE70D;"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                            <Setter Property="Text" Value="&#xE70E;"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Button>
                                                </Grid>
                                                <ItemsControl ItemsSource="{Binding Entries}"
                                                              Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                                                            Padding="12,8">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Opacity" Value="1"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                        <Setter Property="Opacity" Value="0.5"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Original}" Foreground="{StaticResource TextBrush}"
                                                                               FontSize="13" VerticalAlignment="Center"/>
                                                                    <Border CornerRadius="3" Padding="4,1" Margin="8,0,0,0"
                                                                            Background="#333333" VerticalAlignment="Center"
                                                                            Visibility="{Binding CaseSensitive, Converter={StaticResource BoolToVis}}">
                                                                        <TextBlock Text="Aa" FontSize="10" Foreground="{StaticResource HintBrush}"
                                                                                   ToolTip="{loc:Str Dictionary.CaseSensitive}"/>
                                                                    </Border>
                                                                    <Border CornerRadius="3" Padding="5,1" Margin="8,0,0,0"
                                                                            Background="#183B35" VerticalAlignment="Center">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Source}" Value="AutoLearned">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="{loc:Str Dictionary.AutoLearned}" FontSize="10" Foreground="#70C1AE"/>
                                                                    </Border>
                                                                </StackPanel>
                                                                <TextBlock FontSize="11" Foreground="{StaticResource HintBrush}" Margin="0,2,0,0">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding UsageCount}" Value="0">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                    <TextBlock.Text>
                                                                        <MultiBinding Converter="{StaticResource LocalizedFormat}">
                                                                            <Binding Source="{x:Static loc:Loc.Instance}" Path="[Dictionary.UsageCount]"/>
                                                                            <Binding Path="UsageCount"/>
                                                                        </MultiBinding>
                                                                    </TextBlock.Text>
                                                                </TextBlock>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                                <Button Style="{StaticResource IconButtonStyle}" ToolTip="{loc:Str Dictionary.Edit}"
                                                                        AutomationProperties.AutomationId="{Binding Id, StringFormat=DictionaryEditAlias.{0}}"
                                                                        AutomationProperties.Name="{loc:Str Dictionary.Edit}"
                                                                        Command="{Binding DataContext.Dictionary.StartEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}">
                                                                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                                </Button>
                                                                <ui:ToggleSwitch IsChecked="{Binding IsEnabled, Mode=OneWay}" Margin="4,0"
                                                                                 AutomationProperties.AutomationId="{Binding Id, StringFormat=DictionaryAliasEnabled.{0}}"
                                                                                 AutomationProperties.Name="{Binding Original}"
                                                                                 Command="{Binding DataContext.Dictionary.ToggleEnabledCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                 CommandParameter="{Binding}"/>
                                                                <Button Style="{StaticResource IconButtonStyle}" ToolTip="{loc:Str Dictionary.Delete}"
                                                                        AutomationProperties.AutomationId="{Binding Id, StringFormat=DictionaryDeleteAlias.{0}}"
                                                                        AutomationProperties.Name="{loc:Str Dictionary.Delete}"
                                                                        Command="{Binding DataContext.Dictionary.DeleteEntryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}">
                                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                                               Foreground="{StaticResource DangerBrush}"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>

            <!-- Packs Tab (Tab 4) -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          AutomationProperties.AutomationId="DictionaryPacks">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource SettingsScrollBarStyle}"/>
                </ScrollViewer.Resources>
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource TouchScrollViewerStyle}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Dictionary.SelectedTab}" Value="4">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>

                <StackPanel>
                    <!-- Description text -->
                    <TextBlock Foreground="{StaticResource HintBrush}" FontSize="13"
                               TextWrapping="Wrap" Margin="0,0,0,12" Opacity="0.8"
                               Text="{loc:Str Dictionary.PacksDescription}">
                    </TextBlock>

                    <ItemsControl ItemsSource="{Binding Dictionary.Packs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Wrapper for disabled opacity -->
                                <Border Width="220" Margin="0,0,8,8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Opacity" Value="0.55"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Border Background="{StaticResource InputBackgroundBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="8"
                                            ClipToBounds="True">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#333333"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <StackPanel>
                                            <!-- Top accent line -->
                                            <Border Height="3">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>

                                            <StackPanel Margin="14,10,14,12">
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" Text="{Binding Pack.Icon}"
                                                               FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Pack.Name}"
                                                                   Foreground="{StaticResource TextBrush}"
                                                                   FontSize="13" FontWeight="Medium"/>
                                                        <TextBlock Foreground="{StaticResource HintBrush}" FontSize="11">
                                                            <Run Text="{Binding Pack.Terms.Length, Mode=OneWay}"/>
                                                            <Run Text="{loc:Str Dictionary.PackTerms}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <ui:ToggleSwitch Grid.Column="2"
                                                              IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                              VerticalAlignment="Center"
                                                              AutomationProperties.AutomationId="{Binding Pack.Id}"
                                                              AutomationProperties.Name="{Binding Pack.Name}"
                                                              AutomationProperties.HelpText="{Binding TermsPreview}"
                                                              Command="{Binding DataContext.Dictionary.TogglePackCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}"/>
                                                </Grid>

                                                <TextBlock Text="{Binding TermsPreview}"
                                                           Foreground="{StaticResource HintBrush}"
                                                           FontSize="11" TextWrapping="Wrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxHeight="32"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Edit Overlay -->
            <Border Background="#CC1E1E1E"
                    Visibility="{Binding Dictionary.IsEditing, Converter={StaticResource BoolToVis}}"
                    MouseDown="EditOverlay_MouseDown"
                    KeyDown="EditOverlay_KeyDown" Focusable="True">
                <Border Background="{StaticResource InputBackgroundBrush}"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1" CornerRadius="12"
                        Padding="24" MaxWidth="420" MaxHeight="320"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect Color="{StaticResource AccentColor}"
                                          BlurRadius="20" ShadowDepth="0" Opacity="0.15"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Header with type badge -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="{loc:Str Dictionary.EditEntry}"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="16" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Border CornerRadius="4" Padding="6,2" Margin="10,0,0,0"
                                    VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#2A3A5A"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Dictionary.EditEntry.EntryType}" Value="Correction">
                                                <Setter Property="Background" Value="#3A2A1A"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="11" FontWeight="Medium">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#5B9BD5"/>
                                            <Setter Property="Text" Value="{loc:Str Dictionary.Term}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Dictionary.EditEntry.EntryType}" Value="Correction">
                                                    <Setter Property="Foreground" Value="#D4915B"/>
                                                    <Setter Property="Text" Value="{loc:Str Dictionary.Correction}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </StackPanel>

                        <TextBlock Text="{loc:Str Dictionary.Original}" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Dictionary.EditOriginal, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.AutomationId="DictionaryEditOriginal"
                                 AutomationProperties.Name="{loc:Str Dictionary.Original}"
                                 Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="{loc:Str Dictionary.Replacement}" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Dictionary.EditReplacement, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.AutomationId="DictionaryEditReplacement"
                                 AutomationProperties.Name="{loc:Str Dictionary.Replacement}"
                                 Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,12"/>

                        <CheckBox Content="{loc:Str Dictionary.CaseSensitive}"
                                  AutomationProperties.AutomationId="DictionaryEditCaseSensitive"
                                  IsChecked="{Binding Dictionary.EditCaseSensitive}"
                                  Style="{StaticResource InputCheckBoxStyle}" Margin="0,0,0,16"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <ui:Button Content="{loc:Str Dictionary.Cancel}"
                                       AutomationProperties.AutomationId="DictionaryEditCancel"
                                    Command="{Binding Dictionary.CancelEditCommand}"
                                    Appearance="Secondary"
                                    Padding="16,8" Margin="0,0,8,0"/>
                            <ui:Button Content="{loc:Str Dictionary.Save}"
                                       AutomationProperties.AutomationId="DictionaryEditSave"
                                    Command="{Binding Dictionary.SaveEditCommand}"
                                    Appearance="Primary"
                                    Padding="16,8"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>

        </Grid>
    </DockPanel>

            <!-- Guided microphone correction trainer -->
            <Border Panel.ZIndex="20" Background="#EE101318"
                    Visibility="{Binding Dictionary.Training.IsOpen, Converter={StaticResource BoolToVis}}"
                    KeyDown="TrainingOverlay_KeyDown" Focusable="True"
                    FocusManager.IsFocusScope="True"
                    KeyboardNavigation.TabNavigation="Cycle"
                    KeyboardNavigation.ControlTabNavigation="Cycle">
                <Border Background="{StaticResource InputBackgroundBrush}"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1" CornerRadius="12"
                        Padding="18" Margin="12"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Border.Effect>
                        <DropShadowEffect Color="{StaticResource AccentColor}"
                                          BlurRadius="24" ShadowDepth="0" Opacity="0.2"/>
                    </Border.Effect>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="{loc:Str Dictionary.TrainingTitle}"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6"/>

                            <Border Background="#3A2518" CornerRadius="6" Padding="10,8" Margin="0,6,0,12"
                                    Visibility="{Binding Dictionary.Training.HasError, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding Dictionary.Training.ErrorText}"
                                           Foreground="#E9A06F" TextWrapping="Wrap"/>
                            </Border>

                            <!-- Setup -->
                            <StackPanel Visibility="{Binding Dictionary.Training.IsSetup, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{loc:Str Dictionary.TrainingIntro}"
                                           Foreground="{StaticResource HintBrush}" TextWrapping="Wrap" Margin="0,0,0,16"/>
                                <TextBlock x:Name="TrainingTargetLabel"
                                           Text="{loc:Str Dictionary.TrainingTargetWord}" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="TrainingTargetBox"
                                         Text="{Binding Dictionary.Training.TargetWord, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.AutomationId="DictionaryTrainingTarget"
                                         AutomationProperties.LabeledBy="{Binding ElementName=TrainingTargetLabel}"
                                         Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,14"/>
                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="{loc:Str Dictionary.TrainingEngine}" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock Text="{Binding Dictionary.Training.EngineDisplayName}"
                                                   Foreground="{StaticResource TextBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="{loc:Str Dictionary.TrainingModel}" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock Text="{Binding Dictionary.Training.ModelDisplayName}"
                                                   Foreground="{StaticResource TextBrush}"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <ui:Button Content="{loc:Str Dictionary.Cancel}"
                                               Command="{Binding Dictionary.Training.CancelCommand}"
                                               AutomationProperties.AutomationId="DictionaryTrainingSetupCancel"
                                               Appearance="Secondary" Padding="16,8" Margin="0,0,8,0"/>
                                    <ui:Button Content="{loc:Str Dictionary.TrainingContinue}"
                                               Command="{Binding Dictionary.Training.BeginCommand}"
                                               AutomationProperties.AutomationId="DictionaryTrainingCreateSamples"
                                               Appearance="Primary" Padding="16,8"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Samples -->
                            <StackPanel Visibility="{Binding Dictionary.Training.IsSampling, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{loc:Str Dictionary.TrainingSamplesHint}"
                                           Foreground="{StaticResource HintBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding Dictionary.Training.Samples}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                    CornerRadius="8" Padding="10" Margin="0,0,0,6">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock x:Name="TrainingSampleLabel" Grid.Column="0" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextBrush}"
                                                                   VerticalAlignment="Center">
                                                            <TextBlock.Text>
                                                                <MultiBinding Converter="{StaticResource LocalizedFormat}">
                                                                    <Binding Source="{x:Static loc:Loc.Instance}" Path="[Dictionary.TrainingSampleFormat]"/>
                                                                    <Binding Path="Number"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                        <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                                                                   Foreground="{StaticResource HintBrush}"
                                                                   VerticalAlignment="Center" TextWrapping="Wrap"
                                                                   Margin="12,0"/>
                                                        <ui:Button Grid.Column="2" Content="{Binding ActionText}"
                                                                   Command="{Binding DataContext.Dictionary.Training.ToggleSampleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                   AutomationProperties.AutomationId="DictionaryTrainingSampleRecord"
                                                                   CommandParameter="{Binding}" Padding="12,5"/>
                                                    </Grid>
                                                    <TextBox Text="{Binding Sentence, UpdateSourceTrigger=PropertyChanged}"
                                                             AutomationProperties.AutomationId="DictionaryTrainingSampleSentence"
                                                             AutomationProperties.LabeledBy="{Binding ElementName=TrainingSampleLabel}"
                                                             IsReadOnly="{Binding IsSentenceLocked}"
                                                             Style="{StaticResource InputTextBoxStyle}"
                                                             Padding="6,2" Margin="0,6,0,0"/>
                                                    <Border Background="#242A32" CornerRadius="6" Padding="8,5" Margin="0,6,0,0"
                                                            Visibility="{Binding HasRawTranscript, Converter={StaticResource BoolToVis}}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{loc:Str Dictionary.TrainingRawTranscript}"
                                                                       Foreground="{StaticResource HintBrush}" FontSize="11"
                                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding RawTranscript}"
                                                                       Foreground="{StaticResource TextBrush}"
                                                                       TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,2,0,0">
                                    <ui:Button Content="{loc:Str Dictionary.Cancel}"
                                               Command="{Binding Dictionary.Training.CancelCommand}"
                                               AutomationProperties.AutomationId="DictionaryTrainingSamplesCancel"
                                               Appearance="Secondary" Padding="16,8" Margin="0,0,8,0"/>
                                    <ui:Button Content="{loc:Str Dictionary.TrainingReview}"
                                               Command="{Binding Dictionary.Training.ReviewCommand}"
                                               AutomationProperties.AutomationId="DictionaryTrainingReview"
                                               Appearance="Primary" Padding="16,8"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Review -->
                            <StackPanel Visibility="{Binding Dictionary.Training.IsReviewing, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{loc:Str Dictionary.TrainingReviewTitle}"
                                           Foreground="{StaticResource TextBrush}" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Foreground="{StaticResource HintBrush}" TextWrapping="Wrap" Margin="0,6,0,14">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource LocalizedFormat}">
                                            <Binding Source="{x:Static loc:Loc.Instance}" Path="[Dictionary.TrainingReviewHint]"/>
                                            <Binding Path="Dictionary.Training.EngineDisplayName"/>
                                            <Binding Path="Dictionary.Training.ModelDisplayName"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <Border Background="#243029" CornerRadius="6" Padding="10,8" Margin="0,0,0,12"
                                        Visibility="{Binding Dictionary.Training.HasNoCandidates, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{loc:Str Dictionary.TrainingNoCandidates}"
                                               Foreground="{StaticResource HintBrush}" TextWrapping="Wrap"/>
                                </Border>
                                <ItemsControl ItemsSource="{Binding Dictionary.Training.Candidates}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                    CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsApproved}"
                                                                  IsEnabled="{Binding CanApprove}"
                                                                  AutomationProperties.AutomationId="DictionaryTrainingCandidateApproved"
                                                                  VerticalAlignment="Center" Margin="0,0,8,0">
                                                            <AutomationProperties.Name>
                                                                <MultiBinding Converter="{StaticResource LocalizedFormat}">
                                                                    <Binding Source="{x:Static loc:Loc.Instance}" Path="[Dictionary.TrainingApproveCandidateFormat]"/>
                                                                    <Binding Path="Original"/>
                                                                </MultiBinding>
                                                            </AutomationProperties.Name>
                                                        </CheckBox>
                                                        <TextBox Grid.Column="1" Text="{Binding Original, UpdateSourceTrigger=PropertyChanged}"
                                                                 AutomationProperties.AutomationId="DictionaryTrainingCandidateOriginal"
                                                                 Style="{StaticResource InputTextBoxStyle}"/>
                                                        <TextBlock Grid.Column="2" Text="→" Foreground="{StaticResource HintBrush}"
                                                                   VerticalAlignment="Center" Margin="10,0"/>
                                                        <TextBlock Grid.Column="3"
                                                                   Text="{Binding DataContext.Dictionary.Training.TargetWord, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                   Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                                    </Grid>
                                                    <TextBlock Text="{Binding Message}" Foreground="#E9A06F"
                                                               FontSize="11" TextWrapping="Wrap" Margin="28,6,0,0"
                                                               Visibility="{Binding HasMessage, Converter={StaticResource BoolToVis}}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                                    <ui:Button Content="{loc:Str Dictionary.Cancel}"
                                               Command="{Binding Dictionary.Training.CancelCommand}"
                                               AutomationProperties.AutomationId="DictionaryTrainingReviewCancel"
                                               Appearance="Secondary" Padding="16,8" Margin="0,0,8,0"/>
                                    <ui:Button Content="{loc:Str Dictionary.TrainingBackToSamples}"
                                               Command="{Binding Dictionary.Training.BackToSamplesCommand}"
                                               AutomationProperties.AutomationId="DictionaryTrainingBackToSamples"
                                               Appearance="Secondary" Padding="16,8" Margin="0,0,8,0"/>
                                    <ui:Button Content="{loc:Str Dictionary.Save}"
                                               Command="{Binding Dictionary.Training.SaveCommand}"
                                               AutomationProperties.AutomationId="DictionaryTrainingSave"
                                               Appearance="Primary" Padding="16,8"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Border>
    </Grid>
</UserControl>

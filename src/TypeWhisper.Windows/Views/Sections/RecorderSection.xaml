<UserControl x:Class="TypeWhisper.Windows.Views.Sections.RecorderSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="600" Margin="24">
            <TextBlock Text="{loc:Str Nav.Recorder}" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="{loc:Str Recorder.Description}"
                       Style="{StaticResource HintStyle}" Margin="0,0,0,24"/>

            <!-- Recording controls -->
            <Border Background="{StaticResource InputBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="24" HorizontalAlignment="Center" Margin="0,0,0,24">
                <StackPanel HorizontalAlignment="Center">
                    <!-- Mode -->
                    <Grid Width="280" Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{loc:Str Recorder.ModeDictation}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"
                                   FontSize="12.5">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Settings.QuickTranslationModeEnabled}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource HintBrush}"/>
                                            <Setter Property="FontWeight" Value="Normal"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ui:ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding Settings.QuickTranslationModeEnabled}"
                                         OnContent=""
                                         OffContent=""
                                         VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="2"
                                   Text="{loc:Str Recorder.ModeTranslate}"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   FontSize="12.5">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource HintBrush}"/>
                                    <Setter Property="FontWeight" Value="Normal"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Settings.QuickTranslationModeEnabled}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Duration -->
                    <TextBlock Text="{Binding Recorder.DurationText}"
                               FontSize="48" FontFamily="Consolas"
                               Foreground="{StaticResource TextBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>

                    <!-- Record/Stop button -->
                    <ui:Button Appearance="Primary"
                               Command="{Binding Recorder.ToggleRecordingCommand}"
                               HorizontalAlignment="Center"
                               Padding="24,12" FontSize="14">
                        <ui:Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x23FA;" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Grid VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Str Recorder.Record}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Recorder.IsRecording}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{loc:Str Recorder.Stop}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Recorder.IsRecording}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>
                        </ui:Button.Content>
                    </ui:Button>

                    <!-- Level meter -->
                    <ProgressBar Value="{Binding Recorder.AudioLevel}" Maximum="1" Height="4"
                                 Margin="0,16,0,0" Width="200"
                                 Visibility="{Binding Recorder.IsRecording, Converter={StaticResource BoolToVis}}"/>

                    <!-- Status -->
                    <TextBlock Text="{Binding Recorder.StatusText}"
                               Foreground="{StaticResource HintBrush}" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <!-- Recordings list -->
            <TextBlock Text="{loc:Str Recorder.Recordings}" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"
                       Visibility="{Binding Recorder.HasRecordings, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"/>

            <ItemsControl ItemsSource="{Binding Recorder.Recordings}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource InputBackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="14,10" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding FileName}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"/>
                                    <TextBlock Text="{Binding Transcript}" FontSize="11"
                                               Foreground="{StaticResource HintBrush}"
                                               TextTrimming="CharacterEllipsis" MaxHeight="32"
                                               Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding ItemStatusText}" FontSize="11"
                                               Foreground="{StaticResource HintBrush}"
                                               TextTrimming="CharacterEllipsis" MaxHeight="32"
                                               Margin="0,4,0,0"
                                               Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}"/>
                                    <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                               FontSize="10" Foreground="{StaticResource HintBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                            VerticalAlignment="Center" Margin="12,0,0,0">
                                    <ui:Button Appearance="Secondary"
                                               ToolTip="{Binding TranscribeToolTip}" Padding="6,4"
                                               VerticalAlignment="Center"
                                               IsEnabled="{Binding CanTranscribe}"
                                               Command="{Binding DataContext.Recorder.TranscribeRecordingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               CommandParameter="{Binding}">
                                        <ui:SymbolIcon Symbol="Play24"/>
                                    </ui:Button>
                                    <ui:Button Appearance="Secondary"
                                               ToolTip="{loc:Str Recorder.Delete}" Padding="6,4"
                                               VerticalAlignment="Center" Margin="6,0,0,0"
                                               Command="{Binding DataContext.Recorder.DeleteRecordingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               CommandParameter="{Binding}">
                                        <ui:SymbolIcon Symbol="Delete24"/>
                                    </ui:Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>

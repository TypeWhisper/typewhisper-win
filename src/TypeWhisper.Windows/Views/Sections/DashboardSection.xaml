<UserControl x:Class="TypeWhisper.Windows.Views.Sections.DashboardSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters"
             xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:BarHeightConverter x:Key="BarHeightConverter"/>
            <conv:DayLabelConverter x:Key="DayLabelConverter"/>
            <conv:ZeroToVisibilityConverter x:Key="ZeroToVisibility"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="860" Margin="28">

            <Grid Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{loc:Str Dashboard.Title}" Style="{StaticResource PageTitleStyle}"/>
                        <TextBlock Text="{loc:Str Dashboard.Subtitle}"
                                   Style="{StaticResource PageSubtitleStyle}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <Border Style="{StaticResource SettingsSummaryBarStyle}" Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{loc:Str Dashboard.Statistics}" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="{loc:Str Dashboard.StatisticsHint}"
                                   Foreground="{StaticResource HintBrush}" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <RadioButton Content="{loc:Str Dashboard.Weekly}" Style="{StaticResource TabRadioStyle}"
                                     IsChecked="True" Checked="WeekChecked"/>
                        <RadioButton Content="{loc:Str Dashboard.Month}" Style="{StaticResource TabRadioStyle}"
                                     Checked="MonthChecked"/>
                        <RadioButton Content="{loc:Str Dashboard.AllTime}" Style="{StaticResource TabRadioStyle}"
                                     Checked="AllTimeChecked"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 4 Stat Cards -->
            <UniformGrid Rows="1" Columns="4" Margin="0,0,0,24">
                <!-- Words -->
                <Border Background="{StaticResource InputBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="16,20" Margin="0,0,8,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#x270D;" FontSize="18" Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding Dashboard.WordsCount}" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{loc:Str Dashboard.Words}" Foreground="{StaticResource HintBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding Dashboard.WordsTrend}" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,2,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#FF66BB6A"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Dashboard.WordsTrend[0]}" Value="-">
                                            <Setter Property="Foreground" Value="#FFEF5350"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <!-- WPM -->
                <Border Background="{StaticResource InputBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="16,20" Margin="0,0,8,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#x26A1;" FontSize="18" Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding Dashboard.AverageWpm}" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="&#x00D8; WPM" Foreground="{StaticResource HintBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding Dashboard.WpmTrend}" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,2,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#FF66BB6A"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Dashboard.WpmTrend[0]}" Value="-">
                                            <Setter Property="Foreground" Value="#FFEF5350"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <!-- Apps -->
                <Border Background="{StaticResource InputBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="16,20" Margin="0,0,8,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#x2B1A;" FontSize="18" Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding Dashboard.AppsUsed}" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{loc:Str Dashboard.Apps}" Foreground="{StaticResource HintBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding Dashboard.AppsTrend}" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,2,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#FF66BB6A"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Dashboard.AppsTrend[0]}" Value="-">
                                            <Setter Property="Foreground" Value="#FFEF5350"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <!-- Time Saved -->
                <Border Background="{StaticResource InputBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="16,20">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#x23F1;" FontSize="18" Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding Dashboard.TimeSaved}" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{loc:Str Dashboard.TimeSaved}" Foreground="{StaticResource HintBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding Dashboard.TimeTrend}" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,2,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#FF66BB6A"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Dashboard.TimeTrend[0]}" Value="-">
                                            <Setter Property="Foreground" Value="#FFEF5350"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Activity Header -->
            <TextBlock Text="{loc:Str Dashboard.Activity}" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>

            <!-- Empty State -->
            <TextBlock Text="{loc:Str Dashboard.NoActivity}"
                       Foreground="{StaticResource HintBrush}" FontSize="14"
                       HorizontalAlignment="Center" Margin="0,40,0,40"
                       Visibility="{Binding Dashboard.WordsCount, Converter={StaticResource ZeroToVisibility}}"/>

            <!-- Bar Chart -->
            <Border Background="{StaticResource InputBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="16" MinHeight="220"
                    Visibility="{Binding Dashboard.WordsCount, Converter={StaticResource ZeroToVisibility}, ConverterParameter=invert}">
                <ItemsControl ItemsSource="{Binding Dashboard.ChartData}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2,0"
                                  ToolTipService.ShowDuration="60000"
                                  Cursor="Hand"
                                  Background="Transparent">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ToolTip>
                                    <ToolTip Background="{StaticResource SidebarBrush}"
                                             BorderBrush="{StaticResource BorderBrush}"
                                             Foreground="{StaticResource TextBrush}"
                                             Padding="10,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding WordCount}"
                                                       FontSize="15" FontWeight="SemiBold"/>
                                            <TextBlock Text="{loc:Str Dashboard.Words}"
                                                       FontSize="11" Foreground="{StaticResource HintBrush}"
                                                       Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding Date, StringFormat={}{0:dd.MM.yyyy}}"
                                                       FontSize="11" Foreground="{StaticResource HintBrush}"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Grid.ToolTip>
                                <Border Grid.Row="0"
                                        VerticalAlignment="Bottom"
                                        HorizontalAlignment="Stretch"
                                        CornerRadius="3,3,0,0"
                                        Margin="3,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{StaticResource AccentColor}"/>
                                    </Border.Background>
                                    <Border.Height>
                                        <MultiBinding Converter="{StaticResource BarHeightConverter}" ConverterParameter="160">
                                            <Binding Path="WordCount"/>
                                            <Binding Path="DataContext.Dashboard.ChartMaxValue"
                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                        </MultiBinding>
                                    </Border.Height>
                                </Border>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding Date, Converter={StaticResource DayLabelConverter}}"
                                           Foreground="{StaticResource HintBrush}"
                                           FontSize="10"
                                           HorizontalAlignment="Center"
                                           Margin="0,6,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- Setup Wizard shortcut -->
            <Border Style="{StaticResource SettingsCardStyle}" Margin="0,24,0,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Content="{loc:Str Dashboard.RunWizard}"
                                Command="{Binding OpenSetupWizardCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Padding="12,6"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{loc:Str Dashboard.WizardTitle}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="{loc:Str Dashboard.WizardDesc}"
                                   Foreground="{StaticResource HintBrush}" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>

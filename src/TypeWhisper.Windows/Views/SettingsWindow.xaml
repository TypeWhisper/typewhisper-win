<ui:FluentWindow x:Class="TypeWhisper.Windows.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:TypeWhisper.Windows.ViewModels"
        xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters"
        xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization"
        Title="{loc:Str Settings.WindowTitle}"
        MinWidth="1040"
        MinHeight="680"
        Width="1240"
        Height="800"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="None"
        Background="#0E131B"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:NonEmptyToVisibilityConverter x:Key="NonEmptyToVis"/>
        </ResourceDictionary>
    </ui:FluentWindow.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

             <ui:TitleBar Grid.Row="0"
                         Title=""
                         ShowMaximize="False"
                         Margin="18,8,18,0"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="272"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="18,0,0,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="2,8,14,8">
                        <TextBlock Text="TypeWhisper"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding CurrentAppVersion}"
                                   Style="{StaticResource SettingsValueTextStyle}"
                                   Foreground="{StaticResource HintBrush}"/>
                    </DockPanel>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="0,0,14,0">
                        <ItemsControl ItemsSource="{Binding NavigationGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:SettingsNavigationGroup}">
                                    <StackPanel Margin="0,0,0,6">
                                        <TextBlock Text="{Binding Title}"
                                                   Style="{StaticResource NavGroupLabelStyle}"/>
                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:SettingsNavigationItem}">
                                                    <Button Style="{StaticResource SidebarRouteButtonStyle}"
                                                            Command="{Binding DataContext.NavigateToItemCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                                            CommandParameter="{Binding}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding IconGlyph}"
                                                                       FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="12"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Title}"
                                                                       Margin="8,0,0,0"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <Border Grid.Column="1" Background="#283644" Margin="0,0,0,18"/>

                <Grid Grid.Column="2" Margin="0,0,18,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="52"/>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="28,0,28,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding UpdateStatusText}"
                                       Foreground="{StaticResource HintBrush}"
                                       FontSize="11"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding UpdateStatusText, Converter={StaticResource NonEmptyToVis}}"/>
                            <ui:Button Content="{loc:Str Update.Check}"
                                       Command="{Binding CheckForUpdatesCommand}"
                                       Appearance="Secondary"
                                       Margin="0,0,8,0"/>
                            <ui:Button Content="{loc:Str Dashboard.RunWizard}"
                                       Command="{Binding OpenSetupWizardCommand}"
                                       Appearance="Secondary"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Background="#283644"/>

                    <ContentControl Grid.Row="2"
                                    Content="{Binding CurrentSection}"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>

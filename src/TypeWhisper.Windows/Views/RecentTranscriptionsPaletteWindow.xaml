<Window x:Class="TypeWhisper.Windows.Views.RecentTranscriptionsPaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization"
        Title="{loc:Str RecentTranscriptions.Title}"
        Width="520"
        Height="360"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Deactivated="OnDeactivated"
        Loaded="OnLoaded"
        PreviewKeyDown="OnPreviewKeyDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="8"
            Background="#F0141D29"
            BorderBrush="#35FFFFFF"
            BorderThickness="1"
            Padding="14">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="24" Opacity="0.45" ShadowDepth="0"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{loc:Str RecentTranscriptions.Title}"
                       Style="{StaticResource SettingsGroupTitleStyle}"
                       Margin="2,0,0,10"/>

            <TextBox x:Name="SearchBox"
                     Grid.Row="1"
                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputTextBoxStyle}"
                     Margin="0,0,0,10"/>

            <Grid Grid.Row="2">
                <ListBox x:Name="EntriesList"
                         ItemsSource="{Binding FilteredEntries}"
                         SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource SettingsScrollBarStyle}"/>
                    </ListBox.Resources>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,4"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="RowChrome"
                                                CornerRadius="6"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="1">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="RowChrome" Property="Background" Value="#243A5A"/>
                                                <Setter TargetName="RowChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="RowChrome" Property="Background" Value="#1D2B3E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8"
                                    Background="Transparent"
                                    MouseLeftButtonUp="Entry_MouseLeftButtonUp">
                                <StackPanel>
                                    <TextBlock Text="{Binding FinalText}"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"
                                               MaxHeight="40"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Subtitle}"
                                               Foreground="{StaticResource HintBrush}"
                                               FontSize="11"
                                               Margin="0,3,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="{loc:Str RecentTranscriptions.Empty}"
                           Foreground="{StaticResource HintBrush}"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasFilteredEntries}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Grid>
    </Border>
</Window>
